(defvar
  ;; apps + spc
  action_apps+spc (t! unmod_all (switch
    () RA-spc break
  ))

  action_apps+!lctl (t! unmod_all (switch
    () (cmd recent_files.sh) break
  ))

  action_apps+toggle (t! unmod_all (switch
    () M-tab break
  ))

  action_apps_walk_through_same_app (switch
    () A-` break
  )

  action_apps+0 (t! unmod_all (switch 
    () (push-msg "APP:chromeMisc") break
  ))
  action_apps+1 (t! unmod_all (switch 
    () (push-msg "APP:chromeMgmt") break
  ))
  action_apps+2 (t! unmod_all (switch 
