(defvar
;; == App variables =============================================
tmux_prefix A-b
;; tmux_tab_move_left  `$tmux_prefix :swap-window -t -1;select-window -t -1{ent}`
tmux_tab_move_left  (macro $tmux_prefix S-; s w a p - w i n d o w spc - t spc - Digit1 ; s e l e c t - w i n d o w spc - t spc - Digit1 ent)
;; tmux_tab_move_right  `$tmux_prefix :swap-window -t +1;select-window -t +1{ent}`
tmux_tab_move_right  (macro $tmux_prefix S-; s w a p - w i n d o w spc - t spc S-= Digit1 ; s e l e c t - w i n d o w spc - t spc S-= Digit1 ent)

