;; == Seek & Select combos ===============================================
;; !lctl+spc
tmux_action_select_files                   (macro $tmux_prefix w) ;; prefix + w (choose window)
;; !lctl+lsft+spc
tmux_action_select_opened_files            (macro $tmux_prefix w) ;; prefix + w (choose window)
;; !lctl+rsft+spc
;; ___TO_SET___ tmux_action_select_folders         
;; !lalt+spc
;; !lctl+rsft+spc
;; ___TO_SET___ tmux_action_select_folders
;; !lctl+rsft+spc
;; ___TO_SET___ tmux_action_select_folders
;; !lctl+rsft+spc
;; tmux_action_select_folders
tmux_action_select_command                 (macro $tmux_prefix S-;) ;; prefix + : (command prompt)
;; !lmet+spc
;; ___TO_SET___ tmux_action_select_symbol          
;; !lctl+!lalt+spc
;; ___TO_SET___ tmux_action_omnisearch_files       
;; !lctl+!lalt+lsft+spc
