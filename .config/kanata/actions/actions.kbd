  ;; === 1. Special Modifiers actions ====================================
  ;; =====================================================================

  ;; == emojis ============================================================
  ;; emojis + spc
  action_emojis  M-.

  ;; == replace ==========================================================
  ;; replace + spc 
  action_replace_text_in_file (t! unmod_all (switch ;;@autogen@
    ((input virtual vk_nvim)) $nvim_action_replace_text_in_file break
    ((input virtual vk_obsidian)) $obsidian_action_replace_text_in_file break
    () XX break
  ))
  ;; replace + lsft + spc 
