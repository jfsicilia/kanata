(defvar
  ;; This file is intended to be written by the user, and some parts of it
  ;; can be autogenerated by the kananta_sync_actions.py script. The name
  ;; of the action is up to the user, but if you want the script to
  ;; autogenerate some parts, the action must follow the following format:
  ;;
  ;; [!| ]action_<name_of_action> ... (switch  ;;@autogen@
  ;;   ...
  ;; [)]+
  ;;
  ;; Example:
  ;; action_lctl+a (switch ;;@autogen@ 
  ;;   ;; Next 2 lines will be deleted and autogenerated by kanata_sync_actions.py
  ;;   ((input virtual vk_nvim)) $nvim_action_lctl+a break
  ;;   ((input virtual vk_obsidian)) $obsidian_action_lctl+a break
  ;;   () _ break
  ;; )
  ;;
  ;; The goal of autogenerated action content is to create the conditions
  ;; of a switch statement to dynamically determine which action to issue,
  ;; depending on the active application. When an app gains focus, kanata
  ;; will receive a message to press a virtual key; each app has its own
  ;; virtual key (e.g. vk_chrome).
  ;; NOTE: ;;@autogen@ is the tag required to autogenerate the
  ;; switch conditions. Without it, nothing will be autogenerated
  ;; for the action.
  ;;
  ;; Each app that wants its actions to be autogenerated needs to define
  ;; an action_<app>.kbd file in the actions folder. There, it defines each
  ;; action with the same name as in this file, but with the app prefix. The
  ;; file will have the following content:
  ;;
  ;; (defvar
  ;; <app>_action_<name_of_action1>
  ;; <app>_action_<name_of_action2>
  ;; ...
  ;; )
  ;;
  ;; kanata can receive more than one active application at the same time,
  ;; pressing more than one app virtual key (e.g. nvim inside a tmux session
  ;; could press vk_nvim and vk_tmux, depending on the software communicating
  ;; with kanata).
  ;;
  ;; When executing an action, the first app virtual key that matches in the
  ;; switch statement will run its action. The default order of apps is
  ;; alphabetical. To change the default order, an order index can be set
  ;; in the app action file (action_<app>.<index>.kbd). For example:
  ;;
  ;;   action_chrome.10.kbd
  ;;   action_nvim.1.kbd
  ;;
  ;; In this case, nvim will precede chrome in the switch statements.
  ;;
  ;; Sometimes you may want to have an alternate behavior, giving the
  ;; opposite precedence to the apps. In order to achieve that, you can
  ;; reverse the order of the autogenerated conditions.
  ;; Prefixing actions with ! (think of ! as "alternate"), in an autogen-
  ;; marked action, will reverse the order of the conditions.
  ;;
  ;; This will allow, for example, the following use case:
  ;;
  ;; You have a terminal running nvim inside tmux. You would like
  ;; to bind a combo for selecting a pane. Both tmux and nvim support
  ;; panes. You want a combo to work with both apps when they are not active
  ;; at the same time, and when they are active at the same time, the usual
  ;; combo will work for one, and an alternate combo will work for the other.
  ;;
  ;; action_pane_left (t! unmod_all (switch ;;@autogen@
  ;;   ((input virtual vk_nvim)) $nvim_action_pane_left break
  ;;   ((input virtual vk_tmux)) $tmux_action_pane_left break
  ;;   () XX break
  ;; ))
  ;; !action_pane_left (t! unmod_all (switch ;;@autogen@
  ;;   ((input virtual vk_tmux)) $tmux_action_pane_left break
  ;;   ((input virtual vk_nvim)) $nvim_action_pane_left break
  ;;   () XX break
  ;; ))
  ;;
  ;; The default combo will be bound to action_..., working when apps are
  ;; activated separately and giving precedence to one when both are activated
  ;; at the same time. The alternate combo will be bound to !action_...,
  ;; giving precedence to the other app when both apps are active.

  ;; Misc actions ==========================================================
  ;; ralt+spc
  action_apps_launcher (t! unmod_all (switch
    () RA-spc break
  ))

  ;; LCTL actions ==========================================================
  action_lctl+a (t! unmod_all (switch ;;@autogen@ 
    ((input virtual vk_nvim)) $nvim_action_lctl+a break
    () C-a break
  ))
  action_lctl+b (t! unmod_all (switch ;;@autogen@ 
    ((input virtual vk_nvim)) $nvim_action_lctl+b break
    ((input virtual vk_obsidian)) $obsidian_action_lctl+b break
    () C-b break
  ))
  action_lctl+c  (t! unmod_all (switch ;;@autogen@ 
    () C-c  break
  ))
  action_lctl+d (t! unmod_all (switch ;;@autogen@ 
    () C-d break
  ))
  action_lctl+e  (t! unmod_all (switch ;;@autogen@ 
    () C-e  break
