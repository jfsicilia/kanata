  action_lctl+]  (t! unmod_all (switch ;;@autogen@ 
    ((input virtual vk_nvim)) $nvim_action_lctl+] break
    ((input virtual vk_obsidian)) $obsidian_action_lctl+] break
    () C-]  break
  ))  ;; ""
  action_lctl+\  (t! unmod_all (switch ;;@autogen@ 
    () C-\  break
  ))
  action_lctl+-  (t! unmod_all (switch ;;@autogen@ 
    () C--  break
  ))
  action_lctl+=  (t! unmod_all (switch ;;@autogen@ 
    () C-=  break
  ))
  action_lctl+1  (t! unmod_all (switch ;;@autogen@ 
    () C-1  break
  ))
  action_lctl+2  (t! unmod_all (switch ;;@autogen@ 
    () C-2  break
  ))
  action_lctl+3  (t! unmod_all (switch ;;@autogen@ 
    () C-3  break
  ))
  action_lctl+4  (t! unmod_all (switch ;;@autogen@ 
    () C-4  break
  ))
  action_lctl+5  (t! unmod_all (switch ;;@autogen@ 
    () C-5  break
  ))
  action_lctl+6  (t! unmod_all (switch ;;@autogen@ 
    () C-6  break
  ))
  action_lctl+7  (t! unmod_all (switch ;;@autogen@ 
    () C-7  break
  ))
  action_lctl+8  (t! unmod_all (switch ;;@autogen@ 
    () C-8  break
  ))
  action_lctl+9  (t! unmod_all (switch ;;@autogen@ 
    () C-9  break
