;; == Tabs combos ========================================================
;; gui + tabs + l | gui + tabs + right | lsft + rsft | 2x rsft | !met + tab
;; !gui + tabs + l | !gui + tabs + right
tmux_action_tab_next                       (macro C-b n)
;; gui + tabs + h | gui + tabs + left | rsft + lsft | 2x lsft | !met + sft + tab
;; !gui + tabs + h | !gui + tabs + left
tmux_action_tab_prev                       (macro C-b p)
;; gui + tabs (tap) | 2x !lctl/tabs
;; !gui + tabs (tap)
tmux_action_tab_toggle                     (macro C-b l)
;; gui + tabs + t | omni + t
;; !gui + tabs + t
;; tmux_action_tab_new                
;; gui + tabs + w | omni + w
;; !gui + tabs + w
;; tmux_action_tab_close              
