;; gui + pane + spc
;; !gui + pane + spc
;; tmux_action_pane_max               
;; gui + pane + -
;; !gui + pane + -
tmux_action_pane_h_split                   (macro C-b S-') 
;; gui + pane + \
;; !gui + pane + \
tmux_action_pane_v_split                   (macro C-b S-5) 
