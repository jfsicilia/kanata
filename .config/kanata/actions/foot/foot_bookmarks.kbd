foot_action_bookmarks+m            (t! foot_goto_folder $folder_medano)
;; ___TO_SET___ foot_action_bookmarks+n            
;; ___TO_SET___ foot_action_bookmarks+o            
foot_action_bookmarks+p            (t! foot_goto_folder $folder_personal)
;; ___TO_SET___ foot_action_bookmarks+q            
;; ___TO_SET___ foot_action_bookmarks+r            
foot_action_bookmarks+s            (t! foot_goto_folder $folder_settings)
