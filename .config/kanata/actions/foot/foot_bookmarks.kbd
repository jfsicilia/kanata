(deftemplate foot_goto_folder (folder)
  (macro esc d d i c d spc $folder ent)
)
(defvar

;; == bookmarks =========================================================
;; bookmarks + spc
;; ___TO_SET___ foot_action_bookmarks+spc          
;; ___TO_SET___ foot_action_bookmarks+a            
foot_action_bookmarks+b            (t! foot_goto_folder $folder_bookcase)
foot_action_bookmarks+c            (t! foot_goto_folder $folder_scans)
foot_action_bookmarks+d            (t! foot_goto_folder $folder_downloads)
;; ___TO_SET___ foot_action_bookmarks+e            
foot_action_bookmarks+f            (t! foot_goto_folder $folder_photo)
