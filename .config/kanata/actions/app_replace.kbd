(defvar
  ;; @start@ ====== DON'T REMOVE THIS LINE =================================

  ;; == replace ==========================================================
  ;; replace + spc 
  action_replace (t! unmod_all (switch ;;@autogen@
    ((input virtual vk_nvim)) $nvim_action_replace break
    ((input virtual vk_obsidian)) $obsidian_action_replace break
    () XX break
  ))
  ;; replace + lsft + spc 
  action_replace+lsft (t! unmod_all (switch ;;@autogen@
    ((input virtual vk_nvim)) $nvim_action_replace+lsft break
    ((input virtual vk_obsidian)) $obsidian_action_replace+lsft break
    () XX break
  ))
)
