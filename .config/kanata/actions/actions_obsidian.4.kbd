obsidian_action_pane_v_split                   A-\
obsidian_action_pane_close                     A-w
obsidian_action_pane_bookmarks                 A-b
obsidian_action_pane_calendar                  A-c
obsidian_action_pane_day                       A-d
obsidian_action_pane_!day                      A-S-d
obsidian_action_pane_explorer                  A-e
obsidian_action_pane_!explorer                 A-S-e
obsidian_action_pane_find                      C-A-S-f
obsidian_action_pane_go                        C-A-o
obsidian_action_pane_main                      A-m
obsidian_action_pane_outline                   A-o
obsidian_action_pane_properties                A-p
obsidian_action_pane_!properties               A-S-p
obsidian_action_pane_recent                    A-r
obsidian_action_pane_left_sidebar              A-s
obsidian_action_pane_right_sidebar             A-S-s
obsidian_action_pane_tags                      A-t
obsidian_action_pane_vertical_tabs             (macro A-v m)
obsidian_action_pane_graph                     A-g
obsidian_action_pane_backlinks                 A-,
obsidian_action_pane_outlinks                  A-.
obsidian_action_pane_!outlinks                 A-S-.

;; == History combos =====================================================
obsidian_action_hist_next                      C-A-right
obsidian_action_hist_prev                      C-A-left

;; == Text combos ======================================================
obsidian_action_select_all_text                (macro g g S-v S-g)

;; == Omni combos ======================================================
obsidian_action_page_up                        C-b
obsidian_action_page_down                      C-f
