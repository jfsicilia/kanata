(defvar
;; LCTL actions ==========================================================
obsidian_action_lctl+a                         $obsidian_action_select_all_text
obsidian_action_lctl+b                         C-b
obsidian_action_!lctl+b                        C-A-b
obsidian_action_!lctl+e                        C-A-e
obsidian_action_lctl+f                         C-f 
obsidian_action_!lctl+p                        C-A-o
obsidian_action_!lctl+!p                       C-A-p
obsidian_action_!lctl+r                        C-A-M-e 
obsidian_action_lctl+t                         A-C-t
obsidian_action_lctl+!t                        A-C-S-t
obsidian_action_lctl+[                         C-A-left
obsidian_action_lctl+]                         C-A-right
obsidian_action_lctl+;                         (macro C-A-M-e 50 ;) 

;; == Format combos ======================================================
obsidian_action_bold                           C-A-b

;; == Seek & Select combos ===============================================
obsidian_action_select_files                   C-A-o
