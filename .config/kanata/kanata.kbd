;; Use for lctl+[sft]+key combos. If no more modifiers (other than lctl/sft) 
;; are pressed it issues lctl_combo/lctl+sft_combo (depending if shift is 
;; pressed or not) with the lctl released, otherwise does 
;; nothing, to let match the lctl+[sft]+<other modifier>+key by other binding.
;;(deftemplate lctl_sft_combo (lctl_combo lctl+sft_combo)
;;  (switch
;;    (lalt ralt lmet rmet) _ break
;;    (lsft rsft) (multi (t! release3 lctl lsft rsft) $lctl+sft_combo) break
;;    () (multi (t! release1 lctl) $lctl_combo) break
;;  )
;;)

;; Simulate lctl when pressing lalt.
(deftemplate lctl_mimics ()
  (multi 
    ;; If lctl is pressed twice, in a short period, it issues a tab toggle.
    (t! th (t! 2x $combo_tab_toggle) (multi lctl (layer-toggle lctl_layer))) 
    (on-release release-vkey vk_lalt) ;; (lctl+tab mimics lalt+tab)
  )
)

;; Simulate lalt when pressing lmet.
(deftemplate lalt_mimics ()
  (multi lalt (layer-toggle lalt_layout))
)
  
;; Simulate lmet when pressing lctl.
(deftemplate lmet_mimics ()
  (t! th lmet (multi lmet (layer-toggle lmet_layout)))
)

(defsrc
  esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12  
  grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc
  tab  q    w    e    r    t    y    u    i    o    p    [    ]    \
  caps a    s    d    f    g    h    j    k    l    ;    '    ret
  lsft lsgt z    x    c    v    b    n    m    ,    .    /    rsft
  lctl lmet lalt           spc            ralt prnt rctl
) ;;""

;; My default keyboard mapping maps: lclt in the physical lalt key, 
;; lalt in the physical lmet key, lmelt in the physical lctl key. This
;; resembles the ctrl | alt | cmd layout of mac computers.
(deflayer default
  esc   f1    f2   f3   f4   f5   f6   f7   f8    f9   f10  f11  f12 
  grv   1     2    3    4    5    6    7    8     9    0    -    =    bspc
  @tab  @q    @w   @e   @r   @t   @y   @u   @i    @o   @p   [    ]    \
  @caps @a    @s   @d   @f   @g   @h   @j   @k    @l   @;   '    ret
  @lsft @altc @z   @x   @c   @v   @b   @n   @m    ,    .    /    @rsft
  @lmet @lalt @lctl          spc            ralt  prnt rctl
) ;;""

;; Default keyboard mapping with alternative chars (for spanish writing)
;; for a, e, i, o, u and n.
(deflayer default_alt
  esc   f1    f2   f3   f4   f5   f6   f7   f8    f9   f10  f11  f12 
  grv   1     2    3    4    5    6    7    8     9    0    -    =    bspc
  @tab  @q    @w   @!e  @r   @t   @y   @!u  @!i   @!o  @p   [    ]    \
  @caps @!a   @s   @d   @f   @g   @h   @j   @k    @l   @;   '    ret
  @lsft @altc @z   @x   @c   @v   @b   @!n  @m    ,    .    /    @rsft
  @lmet @lalt @lctl          spc            ralt  prnt rctl
) ;;""

(defalias
  ;; lalt behaves as lctl.
  lctl (t! lctl_mimics)

  ;; lalt behaves normally except lalt+tab that mimics lalt+`
  lalt (t! lalt_mimics)

  ;; lmet behaves normally except that lmet+tab mimics ctrl+tab functionality
  ;; (tipically goes to next/previous tab/editor).
  lmet (t! lmet_mimics) 

  ;; gui enables gui_layer for commanding desktops, tabs, panes, windows.
  gui (layer-toggle gui_layer)

  ;; lsft and rsft behaves normally except that lsft+rsft goes to next tab and
  ;; rsft+lsft goes to prev tab.
  lsft (multi lsft (layer-toggle lsft_layer))
  rsft (multi rsft (layer-toggle rsft_layer))

  ;; tab behaves as tab when tapped and new layer when hold.
  tab (t! th tab (layer-toggle tab_layer))

  ;; caps behaves as esc when tapped and gui modifiers when hold.
  caps (t! th esc @lctl)

  ;; Changes the default layout between normal chars and alternative chars (á, ñ, ...)
  toggle_default (multi 
    (on-press toggle-virtualkey vk_alt_chars)
    (switch
      ((input virtual vk_alt_chars)) (layer-switch default) break
      ()  (layer-switch default_alt) break
    )
  )

  ;; Alternative Chars toggle key.
  altc (t! th @toggle_default @gui)  

  ;; mod row.
  a (t! homerowmod $tap_time 450 a @gui)
  s (t! homerowmod $tap_time 400 s @lalt)
  d (t! homerowmod $tap_time 300 d @lsft)
  f (t! homerowmod $tap_time 160 f @lctl)
  g (t! homerowmod $tap_time 160 g @lmet)
  h (t! homerowmod $tap_time 160 h @lmet)
  j (t! homerowmod $tap_time 160 j @lctl)
  k (t! homerowmod $tap_time 300 k @rsft)
  l (t! homerowmod $tap_time 400 l @lalt)
  ; (t! homerowmod $tap_time 450 ; @gui)

  q (t! type q) w (t! type w) e (t! type e) r (t! type r) t (t! type t)
  y (t! type y) u (t! type u) i (t! type i) o (t! type o) p (t! type p)
  ;; a (t! type a) s (t! type s) d (t! type d) f (t! type f) 
  ;; g (t! type g) h (t! type h)
  ;;  j (t! type j) k (t! typek) l (t! type l)
  z (t! type z) x (t! type x) c (t! type c) v (t! type v) b (t! type b) 
  n (t! type n) m (t! type m) 

  ;; Alternative characters for other languages.
  !a (t! homerowmod $tap_time 450 (t! alt_char a) @lmet)
  !e (t! alt_char e) 
  !i (t! alt_char i) 
  !o (t! alt_char o)  
  !u (t! alt_char u) 
  !n (t! alt_char n) 
)
  
(deflayermap (lctl_layer)
  ;; lctl is configured in the physical lalt key (like the cmd key in mac).
  ;; Special treatment is used to allow lctl+tab to mimic alt+tab to switch 
  ;; apps and lctl+` to mimic alt+` to switch apps of the same class.

  ;; Virtual key vk_lalt is "pressed" on first tab pressed and will be
  ;; "released" when lclt is released (see lctl_mimics template).
  tab (switch 
        ((input virtual vk_lalt)) (unmod (lctl) tab) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) tab)) break
  )
  ;; Virtual key vk_lalt is "pressed" on first ` pressed and will be
  ;; "released" when lclt is released (see lctl_mimics template).
  grv (switch 
        ((input virtual vk_lalt)) (unmod (lctl) grv) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) grv)) break
  )

  ;; Allow gui+lctl and lctl+gui to work as expected.
  $lgui (t! th a (multi (release-key lctl) (layer-toggle tabs_layer)))
  $rgui (t! th ; (multi (release-key lctl) (layer-toggle tabs_layer)))

  ;; key combos.
  [ (t! lctl_combo $combo_hist_prev _ _)
  ] (t! lctl_combo $combo_hist_next _ _) 
  b (t! lctl_combo $combo_page_up _ _)
  f (t! lctl_combo $combo_page_down _ _)
  q (t! lctl_combo $combo_close_app _ _) ;; ""

  spc (t! real_lalt_combo $combo_select_files $combo_select_opened_files $combo_select_folders)
  ;; spc (switch
  ;;   ((input real lalt)) (t! lctl_Xsft_combo $combo_select_files $combo_select_opened_files $combo_select_folders) break
  ;;   () _ break
  ;; )
) ;;""

(deflayermap (lalt_layout)
  ;; lalt is configured in the physical lmet key (like the opt key in mac).
  ;; alt+tab works as alt+`
  tab grv
  ;; Allow gui+lalt and lalt+gui to work as expected.
  $lgui (t! th a (multi (release-key lalt) (layer-toggle workspaces_layer)))
  $rgui (t! th ; (multi (release-key lalt) (layer-toggle workspaces_layer)))

  spc (t! real_lmet_combo $combo_select_command _ _)
)

(deflayermap (lmet_layout)
  ;; lmet is configured in the physical lctl key.

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab (multi (release-key lmet) (fork $combo_tab_next $combo_tab_prev (lsft rsft)))
)

(deflayermap (lsft_layer)
  ;; Pressing lsft+rsft (in that order) issues tab_next combo.
  rsft (multi (release-key lsft) $combo_tab_next)

  ;; Allow gui+lsft and lsft+gui to work as expected.
  $lgui (t! th a (multi (release-key lsft) (layer-toggle panes_layer)))
  $rgui (t! th ; (multi (release-key lsft) (layer-toggle panes_layer)))
)

(deflayermap (rsft_layer)
  ;; Pressing rsft+lsft (in that order) issues tab_prev combo.
  lsft (multi (release-key rsft) $combo_tab_prev)
)

(deflayermap (tab_layer)
  ;; tab+r reloads kanata configuration.
  r (fork 
    lrld 
    (multi (release-key lsft) (release-key rsft) (macro RA-spc 300 s y s t e m c t l spc - - u s e r spc r e s t a r t spc k w a n a t a 300 ent)) 
    (lsft rsft)
  )
)

(deflayermap (gui_layer)
  ;; gui button enables windows, desktops, panes and tabs access.
  
  ;; gui+lctl/s -> desktops manipulation.
  s (t! th XX (layer-toggle workspaces_layer))
  lctl (t! th XX (layer-toggle workspaces_layer)) 
  ;; gui+lsft/d -> panes manipulation.
  d (t! th XX (layer-toggle panes_layer))
  lmet (t! th XX (layer-toggle panes_layer)) 
  ;; gui+lctl/f -> tabs manipulation.
  f (t! th (t! 2x $combo_tab_toggle) (layer-toggle tabs_layer))
  lalt (t! th XX (layer-toggle tabs_layer)) 


  ;; gui+spc/h/l/k/j -> window manipulation.
  spc $combo_wnd_max
  h $combo_wnd_left
  l (t! th $combo_wnd_right (layer-toggle workspaces_layer))
  k (t! th $combo_wnd_up (layer-toggle panes_layer))
  j (t! th $combo_wnd_down (layer-toggle tabs_layer))
)

(deflayermap (workspaces_layer)
  ;; desktop/screen manipulation
  j $combo_next_screen 
  k $combo_prev_screen
  l $combo_next_desktop
  h $combo_prev_desktop

  spc (t! th _ (layer-toggle move_workspaces_layer))
)

(deflayermap (move_workspaces_layer)
  ;; desktop/screen manipulation
  j $combo_move_wnd_next_screen 
  k $combo_move_wnd_prev_screen 
  l $combo_move_wnd_next_desktop 
  h $combo_move_wnd_prev_desktop 
)

(deflayermap (tabs_layer)
  ;; tabs manipulation
  h $combo_tab_prev
  l $combo_tab_next

  spc (t! th _ (layer-toggle move_tabs_layer))
)

(deflayermap (move_tabs_layer)
  ;; tabs manipulation
)

(deflayermap (panes_layer)
  ;; panes manipulation
  h $combo_pane_left
  j $combo_pane_below
  k $combo_pane_above
  l $combo_pane_right

  spc (t! th $combo_pane_max (layer-toggle move_panes_layer))
)

(deflayermap (move_panes_layer)
  ;; panes manipulation
)

