;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (bookmarks_layer)

  ;; == SPC/SFT ======================
  spc  (t! th $action_select_fav (t! mod_layer_toggle lsft sft+bookmarks_layer))
  lsft (t! th _                  (t! mod_layer_toggle lsft sft+bookmarks_layer))
  rsft (t! th _                  (t! mod_layer_toggle rsft sft+bookmarks_layer))
  
;; "" BOOKMARKS_LAYER """""""""""""""""""""""""""""
)
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+BOOKMARKS_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""
