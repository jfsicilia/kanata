)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" EDIT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (edit_layer)
  ;; == KEY COMBOS ===================
  j $action_down  
  k $action_up    
  h $action_left  
  l $action_right 

  b $action_page_up
  f $action_page_down

  o $action_open
  p $action_parent
  [ $action_hist_prev
  ] $action_hist_next

  w $action_tab_close
  q $action_close_app

  r $action_rename
  d $action_duplicate
  a $action_select_all 
  n $action_new 

  x $action_cut
  c $action_copy
  v $action_paste
  z $action_undo

  , $action_settings

  bspc del 
  
  ;; == SPC/SFT ======================
  spc  (t! th $action_toggle_select (t! mod_layer_toggle lsft sft+edit_layer))
  lsft (t! th _                     (t! mod_layer_toggle lsft sft+edit_layer))
  rsft (t! th _                     (t! mod_layer_toggle rsft sft+edit_layer))
  
;; "" EDIT_LAYER """"""""""""""""""""""""""""""
)
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+EDIT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (sft+edit_layer)

  ;; == KEY COMBOS ===================
  a (fork $action_clear_select $action_invert_select (rsft))
  n (fork $action_!new $action_!!new (rsft))

  z $action_redo

;; "" SFT+EDIT_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LANG_NUM_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lang/num_layer)

  ;; == KEY COMBOS ===================
  u 7
  i 8
  o 9
  j 4
  k 5 
  l 6
  m 1
  , 2
  . 3
  ralt .

  ;; == SPC/SFT ======================
  spc  (t! th 0 (t! mod_layer_toggle lsft sft+lang/num_layer))
  lsft (t! th _ (t! mod_layer_toggle lsft sft+lang/num_layer))
  rsft (t! th _ (t! mod_layer_toggle rsft sft+lang/num_layer))
  
;; "" LANG_NUM_LAYER """"""""""""""""""""""""""""""
)
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
