;; The fasttyping config was get from... 
;; https://github.com/jtroo/kanata/discussions/1656#discussioncomment-14382030

;; This configuration enables homerowmod where the modifier keys can be
;; used by holding keys in the keyword home row. This is the layout I use:
;;
;;   a    s    d    f    g    h    j    k    l    ;
;;  lgui lalt lsft lctl lmet lmet lctl rsft lalt rgui
;;
;; gui is a custom modifier key that eases the access to windows (gui), 
;; desktops (gui+lalt), panes (gui+lsft) and tabs (gui+lctl) combos.
;;
;; I use the spanish key for < > (under capslock and a key), to toggle
;; between US keyboard and custom ES keyboard (same as US keyboard, but
;; if you press some keys 2 or 3 times in a row you get for example: á, é, ü,
;; ñ, €.

(defcfg
  process-unmapped-keys yes
;;  danger-enable-cmd yes
)

;; Virtual Keys ============================================================
(defvirtualkeys
  vk_lalt lalt  ;; Used to mimic lalt+tab with lctl+tab.

  vk_alt_chars XX ;; Used to toggle alternative characters layout for other 
                  ;; languages.

  vk_fast_typing XX ;; Used to allow fasttyping without triggering modifiers 
                    ;; combos with homrowmod.

  ;; These virtual keys are used by an external program that detects the active 
  ;; window and tells kanata which app is, by pressing one of the next 
  ;; virtual keys. When there is a change in the active window, previous
  ;; virtual key is released and new virtual key is pressed.
  vk_chrome XX
  vk_foot XX
  vk_nvim XX
  vk_zellij XX
  vk_obsidian XX
)


;; Variables ===============================================================
(defvar
  ;; Time config
  tap_time 220
  hold_time 160

  ;; a key and ; key are used as <gui> modifier key when hold.
  lgui a
  rgui ;

  ;; Key combos ============================================================

  ;; == Seek & Select combos ===============================================
  combo_select_files (switch 
    ((input virtual vk_chrome)) C-S-a break
    ((input virtual vk_nvim)) (macro , s f) break
    ((input virtual vk_obsidian)) C-A-o break
    () XX break
  )
  combo_select_opened_files (switch 
    ((input virtual vk_chrome)) XX break
    ((input virtual vk_nvim)) (macro , spc) break
    ((input virtual vk_obsidian)) C-S-A-o break
    () XX break
  )
  combo_select_folders (switch 
    ((input virtual vk_chrome)) XX break
    ((input virtual vk_nvim)) XX break
    ((input virtual vk_obsidian)) C-S-o break
    () XX break
  )
  combo_select_command (switch
    ((input virtual vk_obsidian)) C-A-p break
    () XX break
  )

  ;; == Tabs combos ========================================================
  combo_tab_next (switch 
      ((input virtual vk_chrome)) C-tab break
      ((input virtual vk_zellij)) (macro C-g t l ret) break
      ((input virtual vk_nvim)) (macro esc S-; b n e x t ret) break
      () C-tab break
  )
  combo_tab_prev (switch 
      ((input virtual vk_chrome)) C-S-tab break
      ((input virtual vk_zellij)) (macro C-g t h ret) break
      ((input virtual vk_nvim)) (macro esc S-; b p r e v i o u s ret) break
      () C-S-tab break
  )

  combo_tab_toggle (switch 
      ((input virtual vk_chrome)) A-w break
      ((input virtual vk_zellij)) (macro C-g t tab ret) break
      ((input virtual vk_nvim)) (macro S-; b S-3 ret) break
      () XX break
  )


  ;; == Panes combos =======================================================
  combo_pane_left (switch
    ;;((input virtual vk_zellij)) A-left break
    ((input virtual vk_zellij)) (macro C-g p h ret) break
    ((input virtual vk_nvim)) (macro esc S-; w i n c m d spc h ret) break
    () XX break
  )
  combo_pane_right (switch
    ;;((input virtual vk_zellij)) A-right break
    ((input virtual vk_zellij)) (macro C-g p l ret) break
    ((input virtual vk_nvim)) (macro esc S-; w i n c m d spc l ret) break
    () XX break
  )
  combo_pane_above (switch
    ;;((input virtual vk_zellij)) A-up break
    ((input virtual vk_zellij)) (macro C-g p k ret) break
    ((input virtual vk_nvim)) (macro esc S-; w i n c m d spc k ret) break
    () XX break
  )
  combo_pane_below (switch
    ;;((input virtual vk_zellij)) A-down break
    ((input virtual vk_zellij)) (macro C-g p j ret) break
    ((input virtual vk_nvim)) (macro esc S-; w i n c m d spc j ret) break
    () XX break
  )
  combo_pane_max (switch 
      ((input virtual vk_zellij)) (macro C-g p f ret) break
      ;; ((input virtual vk_nvim)) (macro S-; b S-3 ret) break
      () XX break
  )

  ;; == Window combos ======================================================
  combo_wnd_up M-up
  combo_wnd_down M-down
  combo_wnd_left M-left
  combo_wnd_right M-right
  combo_wnd_max M-m

  combo_move_wnd_next_screen M-S-right
  combo_move_wnd_prev_screen M-S-left
  combo_move_wnd_next_desktop M-C-S-right
  combo_move_wnd_prev_desktop M-C-S-left

  combo_close_app A-f4

  ;; == Desktop combos =====================================================
  combo_next_desktop M-C-right
  combo_prev_desktop M-C-left
  combo_next_screen M-S-down 
  combo_prev_screen M-S-up

  ;; == History combos =====================================================
  combo_hist_next (switch
    ((input virtual vk_chrome)) A-right break
    () XX break
  )
  combo_hist_prev (switch
    ((input virtual vk_chrome)) A-left break
    () XX break
  )

  ;; == Editor combos ======================================================
  ;; Ctrl+b can't be bound in foot, so kanata intercepts it send the 
  ;; corresponding correct foot's keybinding for page up.
  combo_page_up (switch
    ((input virtual vk_foot)) S-pgup break
    () C-b break
  )

  ;; Ctrl+f can't be bound in foot, so kanata intercepts it send the 
  ;; corresponding correct foot's keybinding for page down.
  combo_page_down (switch
    ((input virtual vk_foot)) S-pgdn break
    () C-f break
  )
)

;; Templates ===============================================================

;; == Homerowmod & Fasttyping ==============================================

;; Fasttyping aware typing.
(deftemplate type (action)
  (multi
    (fork
      (hold-for-duration 55 vk_fast_typing)
      XX
      (lctl rctl lalt ralt lmet rmet)
    )
    $action
  )
)

;; Homerow allows modifiers and letters typing. This templates is aware of
;; fasttyping to avoid triggering modifiers when you are typing letters fast.
(deftemplate homerowmod (timeouttap timeouthold keytap keyhold)
  (switch
    ((input virtual vk_fast_typing)) (t! type $keytap) break
    () (tap-hold $timeouttap $timeouthold
         (t! type $keytap)
         $keyhold
       ) break
  )
)

;; == Spanish letters templates ============================================

;; Composes letters with tildes. For example: á, é, ...
(deftemplate tilde (letter)
 (multi (macro bspc rctl (unmod (lsft rsft) ') $letter))
);;"" 

;; Composes letters with birgulilla. For example: ñ, ...
(deftemplate birgulilla (letter)
  (macro bspc rctl S-grave $letter)
)

;; Composes letters with dieresis. For example: ü, ...
(deftemplate dieresis (letter)
  (macro bspc rctl S-' $letter)
)

;; Composes euro letter: €
(deftemplate euro ()
  (macro bspc rctl = c)
)

;; Allows to write alternative characters if letters are typed twice/triple
;; in a short time.
(deftemplate alt_char (letter)
  ;; Only apply 2 times in a row detection if no modifier is pressed.
  (fork 
    (tap-dance-eager 500 (
      ;; 1 tap
      (t! type $letter) 
      ;; 2 taps
      (if-not-equal $letter n (t! type (t! tilde $letter)))
      (if-equal $letter n (t! type (t! birgulilla $letter)))
      ;; 3 taps
      (if-equal $letter e (t! type (t! euro)))
      (if-equal $letter u (t! type(t! dieresis u)))
    ))
    (t! type $letter) ;; If modifier is pressed then use the letter instead.
    (lctl rctl lmet rmet lalt ralt)
  )
)

;; Shorter tap and hold template with default values.
(deftemplate th (tap hold)
  (tap-hold-press $tap_time $hold_time $tap $hold)
)

;; If pressed twice, in a short period, issue the combo.
(deftemplate 2x (combo)
  (tap-dance-eager 300 (XX $combo))
)

;; If pressed 3-times, in a short period, issue the combo.
(deftemplate 3x (combo)
  (tap-dance-eager 400 (XX XX $combo))
)

(deftemplate release1 (k1)
  (release-key $k1)
)
(deftemplate release2 (k1 k2)
  (release-key $k1) (release-key $k2)
)
(deftemplate release3 (k1 k2 k3)
  (release-key $k1) (release-key $k2) (release-key $k3)
)
(deftemplate release4 (k1 k2 k3 k4)
  (release-key $k1) (release-key $k2) (release-key $k3) (release-key $k4)
)

;; Use for lctl+key combos. If no more modifiers (other than lctl) are pressed 
;; it issues the $combo with the lctl released, otherwise does 
;; nothing, to let match the lctl+<other modifier>+key by other binding.
;;(deftemplate lctl_combo (combo)
;;  (fork (multi (t! release1 lctl) $combo) _ (lalt ralt lsft rsft lmet rmet))
;;)
;; Use for lalt+key combos. If no more modifiers (other than lalt) are pressed 
;; it issues the $combo with the lalt released, otherwise does 
;; nothing, to let match the lalt+<other modifier>+key by other binding.
;;(deftemplate lalt_combo (combo)
;;  (fork (multi (t! release1 lalt) $combo) _ (lctl rctl lsft rsft lmet rmet))
;;)
;; Use for lmet+key combos. If no more modifiers (other than lmet) are pressed 
;; it issues the $combo with the lmet released, otherwise does 
;; nothing, to let match the lmet+<other modifier>+key by other binding.
;;(deftemplate lmet_combo (combo)
;;  (fork (multi (t! release1 lmet) $combo) _ (lctl rctl lsft rsft lalt ralt))
;;)

;; Use for lctl+[lsft/rsft]+key combos. If no more modifiers (other than 
;; lctl/sft) are pressed it issues lctl_combo/lctl+lsft_combo/lctl+rsft_combo 
;; (depending if lshift/rshift is pressed or not) with the lctl released, 
;; otherwise does nothing, to let match the 
;; lctl+[lsft/rsft]+<other modifier>+key by other binding.
(deftemplate _inv_mod_ (mod)
  (if-equal $mod lctl (lalt ralt lmet rmet))
  (if-equal $mod lalt (lctl rctl lmet rmet))
  (if-equal $mod lmet (lctl rctl lalt ralt))
)
(deftemplate _combo_ (mod mod_combo mod+lsft_combo mod+rsft_combo)
  (switch
    (t! _inv_mod_ $mod) _ break
    (lsft) (multi (t! release2 $mod lsft) $mod+lsft_combo) break
    (rsft) (multi (t! release2 $mod rsft) $mod+rsft_combo) break
    () (multi (t! release1 $mod) $mod_combo) break
  )
)
(deftemplate lctl_combo (lctl_combo lctl+lsft_combo lctl+rsft_combo)
  (t! _combo_ lctl $lctl_combo $lctl+lsft_combo $lctl+rsft_combo)
)
(deftemplate lalt_combo (lalt_combo lalt+lsft_combo lalt+rsft_combo)
  (t! _combo_ lalt $lalt_combo $lalt+lsft_combo $lalt+rsft_combo)
)
(deftemplate lmet_combo (lmet_combo lmet+lsft_combo lmet+rsft_combo)
  (t! _combo_ lmet $lmet_combo $lmet+lsft_combo $lmet+rsft_combo)
)
(deftemplate real_lalt_combo (lctl_combo lctl+lsft_combo lctl+rsft_combo)
  (switch
    ((input real lalt)) (t! lctl_combo $lctl_combo $lctl+lsft_combo $lctl+rsft_combo) break
    () _ break
  )
)
(deftemplate real_lmet_combo (lalt_combo lalt+lsft_combo lalt+rsft_combo)
  (switch
    ((input real lmet)) (t! lalt_combo $lalt_combo $lalt+lsft_combo $lalt+rsft_combo) break
    () _ break
  )
)
(deftemplate real_lctl_combo (lmet_combo lmet+lsft_combo lmet+rsft_combo)
  (switch
    ((input real lmet)) (t! lmet_combo $lmet_combo $lmet_combo $lmet_combo) break
    () _ break
  )
)

