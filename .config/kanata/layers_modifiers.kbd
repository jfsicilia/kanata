;; "" LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet_layer)
  (t! map_layers "$action_lmet" "lmet" (f j s l d k $!lctl $!lalt lsft rsft))
  (t! map_keys   "$action_lmet"        (f j s l d k tab))

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab $action_tab_next
) 
(deflayermap (lmet+lsft_layer)
  (t! map_layers "$action_lmet+lsft" "lmet+lsft" (f j s l $!lctl $!lalt))
  (t! map_keys   "$action_lmet+lsft"             (f j s l tab))

  tab $action_tab_prev
)

;; "" LMET+RSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet+rsft_layer)
  (t! map_layers "$action_lmet+rsft" "lmet+rsft" (f j s l $!lctl $!lalt))
  (t! map_keys   "$action_lmet+rsft"             (f j s l tab))

  tab $action_tab_prev
)

