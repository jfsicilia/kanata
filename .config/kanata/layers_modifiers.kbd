;; 
;;  ;; == SFT ================
;;  $d|lsft&def      (t! th _ $toggle_lalt+lsft_layer)
;;  lsft             (t! th _ $toggle_lalt+lsft_layer)
;;  $k|rsft&keymap   (t! th _ $toggle_lalt+rsft_layer)
;;  rsft             (t! th _ $toggle_lalt+rsft_layer)

;; "" LALT_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
