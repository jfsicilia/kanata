  lsft            (t! th _ $toggle_lctl+lalt+lmet+lsft_layer)
  $k|rsft&keymap  (t! th _ $toggle_lctl+lalt+lmet+rsft_layer)
  rsft            (t! th _ $toggle_lctl+lalt+lmet+rsft_layer)

