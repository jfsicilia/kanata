(deflayermap (!lalt_layer)
  (t! map_layers "$action_!lalt" "!lalt" (f j a ; d k $!lctl $!lmet lsft rsft))
  (t! map_keys   "$action_!lalt"         (f j a ; d k))
)
(deflayermap (!lalt+lsft_layer)
  (t! map_layers "$action_!lalt+lsft" "!lalt+lsft" (f j a ; $!lctl $!lmet))
  (t! map_keys   "$action_!lalt+lsft"              (f j a ;))
)
(deflayermap (!lalt+rsft_layer)
  (t! map_layers "$action_!lalt+lsft" "!lalt+lsft" (f j a ; $!lctl $!lmet))
