(deflayermap (lalt_layer)
  (t! map_layers "$action_lalt" "lalt" (f j a ; d k $!lctl $!lmet lsft rsft))
  (t! map_keys   "$action_lalt"        (f j a ; d k))
) 
(deflayermap (lalt+lsft_layer)
