(deflayermap (lalt+lmet+rsft_layer)
  ;; == KEY COMBOS ===================
  (t! default_map_keys_except ())

;; "" LALT+LMET+RSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LALT+LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lalt+lmet_layer)
  ;; == KEY COMBOS ===================
  (t! default_map_keys_except (f j d k))

  ;; == LCTL =========================
  $!lctl           (t! th _ $toggle_!lalt+lmet+lctl_layer)
  $f|lctl&autofill (t! th _ $toggle_!lalt+lmet+lctl_layer)
  $j|lctl&jump     (t! th _ $toggle_!lalt+lmet+lctl_layer)

  ;; == LSFT/RSFT ====================
  $d|lsft&def      (t! th _ $toggle_!lalt+lmet+lsft_layer)
  lsft             (t! th _ $toggle_!lalt+lmet+lsft_layer)
  $k|rsft&keymap   (t! th _ $toggle_!lalt+lmet+rsft_layer)
  rsft             (t! th _ $toggle_!lalt+lmet+rsft_layer)
;; "" !LALT+LMET_LAYER """""""""""""""""""
)

