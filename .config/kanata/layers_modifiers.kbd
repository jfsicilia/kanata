;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lalt+lsft_layer)
  (t! map_layers "$action_lalt+lsft" "lalt+lsft"         (f j a ; $!lctl $!lmet))
  (t! map_keys   "$action_lalt+lsft" (f j a ;))
  ;; == KEY COMBOS ===================
  ;; (t! default_map_keys_except ())
;; "" LALT+LSFT_LAYER """""""""""""""""""""""""""""""""""""""""""
