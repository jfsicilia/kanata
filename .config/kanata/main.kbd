;; The fasttyping config was get from... 
;; https://github.com/jtroo/kanata/discussions/1656#discussioncomment-14382030

;; This configuration enables homerowmod where the modifier keys can be
;; used by holding keys in the keyword home row. This is the layout I use:
;;
;;   a    s    d    f    g    h    j    k    l    ;
;;  gui  lalt lsft lctl lmet lmet lctl rsft lalt gui
;;
;; gui is a custom modifier key that eases the access to windows (gui), 
;; desktops (gui+lalt), panes (gui+lsft) and tabs (gui+lctl) combos.
;;
;; I use the spanish key for < > (under capslock and a key), to toggle
;; between US keyboard and custom ES keyboard (same as US keyboard, but
;; if you press some keys 2 or 3 times in a row you get for example: á, é, ü,
;; ñ, €.
;;

;; Virtual Keys ============================================================
(defvirtualkeys
  vk_lalt lalt  ;; Used to mimic lalt+tab with lctl+tab.

  vk_alt_chars    XX ;; Used to toggle alternative characters layout for other 
                     ;; languages.

  vk_fast_typing  XX ;; Used to allow fasttyping without triggering modifiers 
                     ;; combos with homrowmod.
)

;; Variables ===============================================================
(defvar
  ;; Time config
  tap_time  220
  hold_time 160

  ;; Homerowmod, keys in middle line of keyboard behaves as normal when
  ;; tap and modifiers when hold (gui, alt, sft, ctl and met).
  a/gui  a
  s/lalt s
  d/lsft d
  f/lctl f
  g/lmet g
  h/lmet h
  j/lctl j
  k/rsft k
  l/lalt l
  ;/gui  ;

  ;; Caps behaves like esc when tap and omni layer while hold.
  esc/omni caps
  ;; <> Key (Spanish keyboard) behaves like lang toggle when tap and num layer 
  ;; while hold.
  lang/num lsgt

  ;; Y use physical lalt key as lctl, physical lmet key as lalt and physical
  ;; lctl key as lmet.
  !lmet lctl
  !lalt lmet
  !lctl lalt

  ;; Physical ralt key will be used for apps launching/focusing.
  apps ralt

  ;; Physical prnt key will be used for bookmarks.
  bookmarks prnt
)

(defsrc
  esc        f1         f2         f3         f4         f5         f6         f7         f8         f9         f10        f11        f12    del
  grv        1          2          3          4          5          6          7          8          9          0          -          =      bspc
  tab        q          w          e          r          t          y          u          i          o          p          [          ]      \
  caps       a          s          d          f          g          h          j          k          l          ;          '          ret
  lsft       lsgt       z          x          c          v          b          n          m          ,          .          /          rsft   
  lctl       lmet       lalt                             spc                              ralt       prnt       rctl
) ;;""

;; My default keyboard mapping maps: lclt in the physical lalt key, 
;; lalt in the physical lmet key, lmelt in the physical lctl key. This
;; resembles the ctrl | alt | cmd layout of mac computers.
(deflayer default
  esc        f1         f2         f3         f4         f5         f6         f7         f8         f9         f10        f11        f12    del 
  grv        1          2          3          4          5          6          7          8          9          0          -          =      bspc
  @tab/opts  @q         @w         @e         @r         @t         @y         @u         @i         @o         @p         [          ]      \
  @esc/omni  @a/gui     @s/lalt    @d/lsft    @f/lctl    @g/lmet    @h/lmet    @j/lctl    @k/rsft    @l/lalt    @;/gui     '          ret
  @lsft      @lang/num  @z         @x         @c         @v         @b         @n         @m         ,          .          /          @rsft  
  @!lmet     @!lalt     @!lctl                           spc                              @apps      @bookmarks rctl      
) ;;""

;; Default keyboard mapping with alternative chars (for spanish writing)
;; for a, e, i, o, u and n.
(deflayer !default
  esc        f1         f2         f3         f4         f5         f6         f7         f8         f9         f10        f11        f12    del
  grv        1          2          3          4          5          6          7          8          9          0          -          =      bspc
  @tab/opts  @q         @w         @!e        @r         @t         @y         @!u        @!i        @!o        @p         [          ]      \
  @esc/omni  @!a/gui    @s/lalt    @d/lsft    @f/lctl    @g/lmet    @h/lmet    @j/lctl    @k/rsft    @l/lalt    @;/gui     '          ret
  @lsft      @lang/num  @z         @x         @c         @v         @b         @!n        @m         ,          .          /          @rsft  
  @!lmet     @!lalt     @!lctl                           spc                              @apps      @bookmarks rctl      
) ;;""

(defalias
  lctl (multi 
    ;; If lctl is pressed twice, in a short period, it issues a tab toggle.
    ;; If hold switch to lctl_layer.
    (t! th (t! 2x $action_tab_toggle) $toggle_lctl_layer)
    (on-release release-vkey vk_lalt) ;; (lctl+tab mimics lalt+tab)
  )
  !lctl (multi 
    ;; If lctl is pressed twice, in a short period, it issues a tab toggle. 
    ;; If hold switch to lctl_layer and !lctl_layer on top of it.
    (t! th (t! 2x $action_tab_toggle) $toggle_!lctl_layer)
    (on-release release-vkey vk_lalt) ;; (lctl+tab mimics lalt+tab)
  )

  ;; If lalt is pressed twice, in a short period, it issues a pane toggle.
  ;; If hold switch to lalt_layer.
  lalt (t! th (t! 2x $action_pane_toggle) $toggle_lalt_layer)
  ;; If lalt is pressed twice, in a short period, it issues a pane toggle.
  ;; If hold switch to lalt_layer and !lalt_layer on top of it.
  !lalt (t! th (t! 2x $action_pane_toggle) $toggle_!lalt_layer)

  ;; If hold switch to lmet_layer.
  lmet (t! th lmet $toggle_lmet_layer)
  ;; If hold switch to lmet_layer and !lmet_layer on top of it.
  !lmet (t! th lmet $toggle_!lmet_layer)

  ;; Switch to gui_layer, that enables commanding desktops, tabs, panes, windows.
  gui $toggle_gui_layer

  ;; lsft and rsft behaves normally except that lsft+rsft goes to next tab and
  ;; rsft+lsft goes to prev tab. Also tapping twice on lsft or rsft goes
  ;; to previous tab or next tab respectively.
  lsft (t! th (t! 2x $action_tab_prev) $toggle_lsft_layer)
  rsft (t! th (t! 2x $action_tab_next) $toggle_rsft_layer)

  ;; tab behaves as tab when tapped and opts_layer when hold.
  tab/opts (t! th tab $toggle_opts_layer)

  ;; Pyhsical prnt behaves as prnt when tapped and bookmarks_layer when hold.
  bookmarks (t! th $bookmarks $toggle_bookmarks_layer)

  ;; Physical ralt behaves switches apps_layer when hold.
  apps (t! th $apps $toggle_apps_layer) 

  omni  $toggle_omni_layer

  ;; caps behaves as esc when tapped and gui modifiers when hold.
  esc/omni (t! th esc @omni)

  ;; Alternative Chars toggle key. Changes the default layout between normal 
  ;; chars and alternative chars (á, ñ, ...)
  toggle_kbd_lang (multi 
    (on-press toggle-virtualkey vk_alt_chars)
    (switch
      ((input virtual vk_alt_chars)) (layer-switch default) break
      ()  (layer-switch !default) break
    )
  )

  lang/num (t! th @toggle_kbd_lang $toggle_num_layer)

  a/gui  (t! homerowmod $tap_time $hold_time a @gui)
  s/lalt (t! homerowmod $tap_time $hold_time s @lalt)
  d/lsft (t! homerowmod $tap_time $hold_time d @lsft)
  f/lctl (t! homerowmod $tap_time $hold_time f @lctl)
  g/lmet (t! homerowmod $tap_time $hold_time g @lmet)
  h/lmet (t! homerowmod $tap_time $hold_time h @lmet)
  j/lctl (t! homerowmod $tap_time $hold_time j @lctl)
  k/rsft (t! homerowmod $tap_time $hold_time k @rsft)
  l/lalt (t! homerowmod $tap_time $hold_time l @lalt)
  ;/gui  (t! homerowmod $tap_time $hold_time ; @gui)

  q (t! type q) w (t! type w) e (t! type e) r (t! type r) t (t! type t)
  y (t! type y) u (t! type u) i (t! type i) o (t! type o) p (t! type p)
  ;; a (t! type a) s (t! type s) d (t! type d) f (t! type f) 
  ;; g (t! type g) h (t! type h)
  ;;  j (t! type j) k (t! typek) l (t! type l)
  z (t! type z) x (t! type x) c (t! type c) v (t! type v) b (t! type b) 
  n (t! type n) m (t! type m) 

  ;; Alternative characters for other languages.
  !a/gui (t! homerowmod $tap_time $hold_time (t! alt_char a) @gui)
  !e     (t! alt_char e) 
  !i     (t! alt_char i) 
  !o     (t! alt_char o)  
  !u     (t! alt_char u) 
  !n     (t! alt_char n) 

  ;; "" ALIAS """"""""""""""""""""""""
)

  
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LCTL_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lctl_layer)
  ;; lctl is configured in the physical lalt key (like the cmd key in mac).
  ;; Special treatment is used to allow lctl+tab to mimic alt+tab to switch 
  ;; apps and lctl+` to mimic alt+` to switch apps of the same class.

  ;; == FOCUS APP ===================
  ;; Virtual key vk_lalt is "pressed" on first tab pressed and will be
  ;; "released" when lclt is released.
  tab (switch 
        ((input virtual vk_lalt)) (unmod (lctl) tab) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) tab)) break
  )
  ;; Virtual key vk_lalt is "pressed" on first ` pressed and will be
  ;; "released" when lclt is released.
  grv (switch 
        ((input virtual vk_lalt)) (unmod (lctl) grv) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) grv)) break
  )
  
  ;; == WORKSPACES ===================
  $a/gui (t! th _ (multi (release-key lctl) $toggle_tabs_layer))
  $;/gui (t! th _ (multi (release-key lctl) $toggle_tabs_layer))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lctl+lalt_layer)
  $s/lalt (t! th _ $toggle_lctl+lalt_layer)
  $l/lalt (t! th _ $toggle_lctl+lalt_layer)

  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_lctl+lmet_layer)
  $g/lmet (t! th _ $toggle_lctl+lmet_layer)
  $h/lmet (t! th _ $toggle_lctl+lmet_layer)

  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lctl_layer)
  $d/lsft (t! th _ $toggle_lsft+lctl_layer)
  lsft    (t! th _ $toggle_lsft+lctl_layer)
  $k/rsft (t! th _ $toggle_rsft+lctl_layer)
  rsft    (t! th _ $toggle_rsft+lctl_layer)
  
;; "" LCTL_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+LCTL_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (sft+lctl_layer)

  ;; == KEY COMBOS ===================
;;  t $action_lctl+!t

;; "" SFT+LCTL_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LCTL_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lctl_layer)

  ;; == KEY COMBOS ===================
;;  spc $action_select_files 

  ;; Nav
 ;; b $action_!lctl+b

  ;; == WORKSPACES ===================
  $a/gui (t! th _ (multi (release-key $!lctl) $toggle_tabs_layer))
  $;/gui (t! th _ (multi (release-key $!lctl) $toggle_tabs_layer))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_!lctl+lalt_layer)
  $s/lalt (t! th _ $toggle_!lctl+lalt_layer)
  $l/lalt (t! th _ $toggle_!lctl+lalt_layer)
                                                                 
  ;; == LMET =========================                           
  $!lmet  (t! th _ $toggle_!lctl+lmet_layer)
  $g/lmet (t! th _ $toggle_!lctl+lmet_layer)
  $h/lmet (t! th _ $toggle_!lctl+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lctl_layer)
  lsft    (t! th _ $toggle_!lsft+lctl_layer)
  $k/rsft (t! th _ $toggle_!rsft+lctl_layer)
  rsft    (t! th _ $toggle_!rsft+lctl_layer)

;; "" !LCTL_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !SFT+LCTL_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!sft+lctl_layer)
  ;; == KEY COMBOS ===================
  spc (fork $action_select_opened_files $action_select_folders (rsft)) 

;; "" !SFT+LCTL_LAYER """""""""""""""
)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lalt_layer)
  ;; == KEY COMBOS ===================

  ;; lalt is configured in the physical lmet key (like the opt key in mac).
  ;; alt+tab works as alt+`
  tab grv

  ;; == WORKSPACES ===================
  $a/gui (t! th _ (multi (release-key lalt) $toggle_workspaces_layer))
  $;/gui (t! th _ (multi (release-key lalt) $toggle_workspaces_layer))

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_lalt+lctl_layer)
  $f/lctl (t! th _ $toggle_lalt+lctl_layer)
  $j/lctl (t! th _ $toggle_lalt+lctl_layer)

  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_lalt+lmet_layer)
 
  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lalt_layer)
  $d/lsft (t! th _ $toggle_lsft+lalt_layer)
  lsft    (t! th _ $toggle_lsft+lalt_layer)
  $k/rsft (t! th _ $toggle_rsft+lalt_layer)
  rsft    (t! th _ $toggle_rsft+lalt_layer)

;; "" LALT_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (sft+lalt_layer)

;; "" SFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lalt_layer)

  ;; == KEY COMBOS ===================
  spc $action_select_command

  ;; == WORKSPACES ===================
  $a/gui (t! th _ (multi (release-key $!lalt) $toggle_panes_layer))
  $;/gui (t! th _ (multi (release-key $!lalt) $toggle_panes_layer))

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_!lalt+lctl_layer)
  $f/lctl (t! th _ $toggle_!lalt+lctl_layer)
  $j/lctl (t! th _ $toggle_!lalt+lctl_layer)
                                                                 
  ;; == LMET =========================                           
  $!lmet  (t! th _ $toggle_!lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_!lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_!lalt+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lalt_layer)
  lsft    (t! th _ $toggle_!lsft+lalt_layer)
  $k/rsft (t! th _ $toggle_!rsft+lalt_layer)
  rsft    (t! th _ $toggle_!rsft+lalt_layer)

;; "" !LALT_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !SFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!sft+lalt_layer)

;; "" !SFT+LALT_LAYER """""""""""""""
)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet_layer)

  ;; == KEY COMBOS ===================

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab (multi (release-key lmet) (fork $action_tab_next $action_tab_prev (lsft rsft)))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lmet+lalt_layer)
  $s/lalt (t! th _ $toggle_lmet+lalt_layer)
  $l/lalt (t! th _ $toggle_lmet+lalt_layer)

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_lmet+lctl_layer)
  $f/lctl (t! th _ $toggle_lmet+lctl_layer)
  $j/lctl (t! th _ $toggle_lmet+lctl_layer)
  
  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lmet_layer)
  $d/lsft (t! th _ $toggle_lsft+lmet_layer)
  lsft    (t! th _ $toggle_lsft+lmet_layer)
  $k/rsft (t! th _ $toggle_rsft+lmet_layer)
  rsft    (t! th _ $toggle_rsft+lmet_layer)

;; "" LMET_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (sft+lmet_layer)

;; "" SFT+LMET_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LMET_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lmet_layer)

  ;; == KEY COMBOS ===================
  spc $action_select_symbol

  ;; == WORKSPACES =========================
  $a/gui (t! th _ (multi (release-key $!lmet) $toggle_workspaces_layer))
  $;/gui (t! th _ (multi (release-key $!lmet) $toggle_workspaces_layer))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_!lmet+lalt_layer)
  $s/lalt (t! th _ $toggle_!lmet+lalt_layer)
  $l/lalt (t! th _ $toggle_!lmet+lalt_layer)
                                                                 
  ;; == LCTL =========================                           
  $!lctl  (t! th _ $toggle_!lmet+lctl_layer)
  $f/lctl (t! th _ $toggle_!lmet+lctl_layer)
  $j/lctl (t! th _ $toggle_!lmet+lctl_layer)
  
  ;; == SPC/LSFT/RSFT ================
  $d/lsft (t! th _ $toggle_!lsft+lmet_layer)
  lsft    (t! th _ $toggle_!lsft+lmet_layer)
  $k/rsft (t! th _ $toggle_!rsft+lmet_layer)
  rsft    (t! th _ $toggle_!rsft+lmet_layer)

;; "" !LMET_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !SFT+LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!sft+lmet_layer)

;; "" !SFT+LMET_LAYER """"""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LCTL+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lctl+lalt_layer)

  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_lctl+lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_lctl+lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_lctl+lalt+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_lsft+lctl+lalt_layer)
  lsft    (t! th _ $toggle_lsft+lctl+lalt_layer)
  $k/rsft (t! th _ $toggle_rsft+lctl+lalt_layer)
  rsft    (t! th _ $toggle_rsft+lctl+lalt_layer)
;; "" LCTL+LALT_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" SFT+LCTL+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (sft+lctl+lalt_layer)

;; "" SFT+LCTL+LALT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LCTL+LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lctl+lalt_layer)

  ;; == KEY COMBOS ===================
  spc $action_omnisearch_files
  
  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_!lctl+lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_!lctl+lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_!lctl+lalt+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lctl+lalt_layer)
  lsft    (t! th _ $toggle_!lsft+lctl+lalt_layer)
  $k/rsft (t! th _ $toggle_!rsft+lctl+lalt_layer)
  rsft    (t! th _ $toggle_!rsft+lctl+lalt_layer)

;; "" !LCTL+LALT_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
