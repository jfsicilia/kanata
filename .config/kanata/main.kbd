(deflayermap (!sft+lctl+lalt_layer)

  ;; == KEY COMBOS ===================
  spc $action_omnisearch_file

;; "" !SFT+LCTL+LALT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
