  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lctl+lmet+lalt_layer)
  $s/lalt (t! th _ $toggle_lctl+lmet+lalt_layer)
  $l/lalt (t! th _ $toggle_lctl+lmet+lalt_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_lsft+lctl+lmet_layer)
  lsft    (t! th _ $toggle_lsft+lctl+lmet_layer)
  $k/rsft (t! th _ $toggle_rsft+lctl+lmet_layer)
  rsft    (t! th _ $toggle_rsft+lctl+lmet_layer)

;; "" LCTL+LMET_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
