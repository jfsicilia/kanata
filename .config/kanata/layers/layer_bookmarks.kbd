  q $action_bookmarks_q
  r $action_bookmarks_r
  s $action_bookmarks_s
  t $action_bookmarks_t
  u $action_bookmarks_u
  v $action_bookmarks_v
  w $action_bookmarks_w
  x $action_bookmarks_x
  y $action_bookmarks_y
  z $action_bookmarks_z
  - $action_bookmarks_-
)

(deflayermap (bookmarks+lsft_layer)
