;; "" BOOKMARKS_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (bookmarks_layer)
  (t! map_layers _ "bookmarks" (lsft rsft))

  a $action_bookmarks_a
  b $action_bookmarks_b
  c $action_bookmarks_c
  d $action_bookmarks_d
  e $action_bookmarks_e
  f $action_bookmarks_f
  g $action_bookmarks_g
  h $action_bookmarks_h
  i $action_bookmarks_i
