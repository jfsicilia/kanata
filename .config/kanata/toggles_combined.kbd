  toggle_modD_&_lsft_+rsft_layer     (t! toggle_mod_2layer  rsft       modD+rsft_layer rsft_layer)

  toggle_modF_&_lctl_layer           (t! toggle_mod_2layer  lctl       modF_layer      lctl_layer)
