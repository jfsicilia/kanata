  toggle_mod/_&_window+rsft_layer    (t! toggle_mod_2layer  rsft       mod/+rsft_layer window+rsft_layer )

  toggle_window_layer_&_mod/         (t! toggle_2layer                 window_layer      mod/_layer       )
  toggle_window+lsft_layer_&_mod/    (t! toggle_mod_2layer  lsft       window+lsft_layer mod/+lsft_layer  )
  toggle_window+rsft_layer_&_mod/    (t! toggle_mod_2layer  rsft       window+rsft_layer mod/+rsft_layer  )
)
