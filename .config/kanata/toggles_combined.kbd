  toggle_modK_&_rsft_+rsft_layer     (t! toggle_mod_2layer  rsft       modK+rsft_layer rsft_layer)

  toggle_modL_&_lalt_layer           (t! toggle_mod_2layer  lalt       modL_layer      lalt_layer  )
  toggle_modL_&_lalt_+lsft_layer     (t! toggle_2mod_2layer lalt lsft  modL+lsft_layer lalt+lsft_layer)
  toggle_modL_&_lalt_+rsft_layer     (t! toggle_2mod_2layer lalt rsft  modL+rsft_layer lalt+rsft_layer)

  toggle_tab_layer_&_modM            (t! toggle_2layer                 tab_layer      modM_layer     )
