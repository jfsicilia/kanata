  toggle_mod;_&_lmet_layer           (t! toggle_mod_2layer  lmet       mod;_layer      lmet_layer)
  toggle_mod;_&_lmet_+lsft_layer     (t! toggle_2mod_2layer lmet lsft  mod;+lsft_layer lmet+lsft_layer)
  toggle_mod;_&_lmet_+rsft_layer     (t! toggle_2mod_2layer lmet rsft  mod;+rsft_layer lmet+rsft_layer)

  toggle_mod/_&_window_layer         (t! toggle_2layer                 mod/_layer      window_layer)
