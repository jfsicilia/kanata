(defvar
  toggle_file_&_!lctl_layer          (t! toggle_mod_3layer  lctl       file_layer         lctl_layer      !lctl_layer      )
  toggle_file_&_!lctl+lsft_layer     (t! toggle_2mod_3layer lctl lsft  file+lsft_layer    lctl+lsft_layer !lctl+lsft_layer )
  toggle_file_&_!lctl+rsft_layer     (t! toggle_2mod_3layer lctl rsft  file+rsft_layer    lctl+rsft_layer !lctl+rsft_layer )

  toggle_replace_&_!lmet_layer       (t! toggle_mod_3layer  lmet       replace_layer      lmet_layer      !lmet_layer      )
