  h     $action_tabs_move_left
  left  $action_tabs_move_left
  l     $action_tabs_move_right
  right $action_tabs_move_right
  j     $action_tabs_move_first
  down  $action_tabs_move_first
  k     $action_tabs_move_last
  up    $action_tabs_move_last
;; "" TABS+MOVE_LAYER """"""""""""""""
)

