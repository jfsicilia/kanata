(deflayermap (tabs+lsft_layer)
  ;; == KEY COMBOS ===================
  t $action_tabs_undo_close
  ;; "" TABS+LSFT_LAYER """""""""""""""
)
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
