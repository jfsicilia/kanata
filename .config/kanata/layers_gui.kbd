  k     $action_panes_swap_above
  j     $action_panes_swap_below
  left  $action_panes_swap_left
  right $action_panes_swap_right
  up    $action_panes_swap_above
  down  $action_panes_swap_below

  ;; "" PANES+SWAP_LAYER """"""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" TABS LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (tabs_layer)
  ;; == KEY COMBOS ===================
  spc   $action_tabs

  h     $action_tabs_prev
  left  $action_tabs_prev
  l     $action_tabs_next
  right $action_tabs_next
  j     $action_tabs_first
  down  $action_tabs_first
  k     $action_tabs_last
  up    $action_tabs_last

  t     $action_tabs_new
  w     $action_tabs_close

  1     $action_tabs_goto_1
  2     $action_tabs_goto_2
  3     $action_tabs_goto_3
  4     $action_tabs_goto_4
  5     $action_tabs_goto_5
  6     $action_tabs_goto_6
  7     $action_tabs_goto_7
  8     $action_tabs_goto_8
  9     $action_tabs_goto_last

;;  ;; == SFT ======================
  lsft  (t! th _ $toggle_tabs+lsft_layer)
  rsft  (t! th _ $toggle_tabs+rsft_layer)
  $move (t! th _ $toggle_tabs+move_layer)

  ;; "" TABS LAYER """"""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" TABS+MOVE_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
