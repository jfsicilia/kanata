;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" TAB LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (tab_layer)
  ;; == KEY COMBOS ===================
  spc   $action_tab

  h     $action_tab_prev
  left  $action_tab_prev
  l     $action_tab_next
  right $action_tab_next
  j     $action_tab_first
  down  $action_tab_first
  up    $action_tab_last

  t     $action_tab_new
  w     $action_tab_close

  1     $action_tab_goto_1
  2     $action_tab_goto_2
  3     $action_tab_goto_3
  4     $action_tab_goto_4
  5     $action_tab_goto_5
  6     $action_tab_goto_6
  7     $action_tab_goto_7
  8     $action_tab_goto_8
  9     $action_tab_goto_last

  ;; == SFT ======================
  $d|lsft&def     (t! th _                    $toggle_tab+lsft_layer)
  $k|rsft&keymap  (t! th $action_tab_last    $toggle_tab+rsft_layer)
  lsft            (t! th _                    $toggle_tab+lsft_layer)
  rsft            (t! th _                    $toggle_tab+rsft_layer)

  ;; == Gui Actions ========================
  $move (t! th _ $toggle_tab+move_layer)

  ;; "" TAB LAYER """"""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
