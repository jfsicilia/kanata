  (defvar
  ;; == GUI LAYERS =========================================================

  ;; Window layer
  toggle_window_layer                (t! toggle_layer             window_layer)
  toggle_window+lsft_layer           (t! toggle_mod_layer   lsft  window+lsft_layer)
  toggle_window+rsft_layer           (t! toggle_mod_layer   rsft  window+rsft_layer)
  toggle_window+move_layer           (t! toggle_layer             window+move_layer)
  toggle_window+resize_layer         (t! toggle_layer             window+resize_layer)
  toggle_window+snap_layer           (t! toggle_layer             window+snap_layer)
  toggle_window+swap_layer           (t! toggle_layer             window+swap_layer)

  ;; Workspace layer
  toggle_workspace_layer             (t! toggle_layer             workspace_layer)
  toggle_workspace+lsft_layer        (t! toggle_mod_layer   lsft  workspace+lsft_layer)
  toggle_workspace+rsft_layer        (t! toggle_mod_layer   rsft  workspace+rsft_layer)
  toggle_workspace+move_layer        (t! toggle_layer             workspace+move_layer)

  ;; Pane layer
  toggle_pane_layer                  (t! toggle_layer             pane_layer)
  toggle_pane+lsft_layer             (t! toggle_mod_layer   lsft  pane+lsft_layer)
  toggle_pane+rsft_layer             (t! toggle_mod_layer   rsft  pane+rsft_layer)
  toggle_pane+move_layer             (t! toggle_layer             pane+move_layer)
  toggle_pane+resize_layer           (t! toggle_layer             pane+resize_layer)
  toggle_pane+snap_layer             (t! toggle_layer             pane+snap_layer)
  toggle_pane+swap_layer             (t! toggle_layer             pane+swap_layer)

  ;; Tab layer
  toggle_tab_layer                   (t! toggle_layer             tab_layer)
  toggle_tab+lsft_layer              (t! toggle_mod_layer   lsft  tab+lsft_layer)
  toggle_tab+rsft_layer              (t! toggle_mod_layer   rsft  tab+rsft_layer)
  toggle_tab+move_layer              (t! toggle_layer             tab+move_layer)

  ;; Group layer
  toggle_group_layer                 (t! toggle_layer             group_layer)
  toggle_group+lsft_layer            (t! toggle_mod_layer   lsft  group+lsft_layer)
  toggle_group+rsft_layer            (t! toggle_mod_layer   rsft  group+rsft_layer)

  ;; Session layer
  toggle_session_layer               (t! toggle_layer             session_layer)
  toggle_session+lsft_layer          (t! toggle_mod_layer   lsft  session+lsft_layer)
  toggle_session+rsft_layer          (t! toggle_mod_layer   rsft  session+rsft_layer)

)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WINDOWS_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (window_layer)
  ;; == KEY COMBOS ===================
  h            $action_window_left
  l            $action_window_right
  j            $action_window_down

  ent          $action_window_max

  ;; == Gui Actions ========================

  ;; == SFT ======================
  $d|lsft&def     (t! th _                   $toggle_window+lsft_layer)
  $k|rsft&keymap  (t! th $action_window_up  $toggle_window+rsft_layer)
  lsft            (t! th _                   $toggle_window+lsft_layer)
  rsft            (t! th _                   $toggle_window+rsft_layer)
;; "" WINDOWS_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WINDOWS+LSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (window+lsft_layer)

;; "" WINDOWS+LSFT_LAYER """"""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WINDOWS+RSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (window+rsft_layer)

;; "" WINDOWS+RSFT_LAYER """"""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WORKSPACES LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (workspace_layer)
  ;; == KEY COMBOS ===================
  j $action_screen_next
  l $action_desktop_next
  h $action_desktop_prev

  ;; == Gui Actions ========================
  $move (t! th _ $toggle_workspace+move_layer)

  ;; == SFT ======================
  $d|lsft&def     (t! th _                    $toggle_workspace+lsft_layer)
  $k|rsft&keymap  (t! th $action_screen_prev $toggle_workspace+rsft_layer)
  lsft            (t! th _                    $toggle_workspace+lsft_layer)
  rsft            (t! th _                    $toggle_workspace+rsft_layer)
  ;; "" WORKSPACES LAYER """"""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WORKSPACES+MOVE_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (workspace+move_layer)
  ;; == KEY COMBOS ===================
  j $action_screen_next_move_window
  k $action_screen_prev_move_window
  l $action_desktop_next_move_window
  h $action_desktop_prev_move_window

  ;; "" WORKSPACES+MOVE_LAYER """"""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WORKSPACES+LSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (workspace+lsft_layer)
  ;; == KEY COMBOS ===================

  ;; "" WORKSPACES+LSFT_LAYER """"""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" WORKSPACES+RSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (workspace+rsft_layer)
  ;; == KEY COMBOS ===================

  ;; "" WORKSPACES+RSFT_LAYER """"""""""""""""""""
