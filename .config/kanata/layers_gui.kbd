  k     $action_panes_move_above
  up    $action_panes_move_above
  l     $action_panes_move_right
  right $action_panes_move_right

;; "" PANES+MOVE_LAYER """""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" PANES+SNAP_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""
