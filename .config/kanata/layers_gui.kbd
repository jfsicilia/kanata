  k     $action_panes_resize_above
  j     $action_panes_resize_below
  left  $action_panes_resize_left
  right $action_panes_resize_right
  up    $action_panes_resize_above
  down  $action_panes_resize_below

  ;; "" PANES+RESIZE_LAYER """"""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
