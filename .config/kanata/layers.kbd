;; "" GUI_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (gui_layer)
  ;; gui button enables windows, desktops, panes and tabs access.
  
  ;; == WORKSPACES ===================
  $s/work      (t! th XX $toggle_workspaces_layer)
  $!lmet/work  (t! th XX $toggle_workspaces_layer)

  ;; == PANES ========================
  $d/pane      (t! th $action_pane_toggle $toggle_panes_layer)
  $!lalt/pane  (t! th $action_pane_toggle $toggle_panes_layer)


  ;; == TABS =========================
  $f/tabs      (t! th $action_tab_toggle $toggle_tabs_layer)
  $!lctl/tabs  (t! th $action_tab_toggle $toggle_tabs_layer)

  ;; == WINDOWS ======================
  h            $action_wnd_left
  $l/work      (t! th $action_wnd_right $toggle_workspaces_layer)
  $k/pane      (t! th $action_wnd_up    $toggle_panes_layer)
  $j/tabs      (t! th $action_wnd_down  $toggle_tabs_layer)

  ;; == SPC/SFT ======================
  spc          (t! th $action_wnd_max $toggle_lsft+gui_layer)
  lsft         (t! th _               $toggle_lsft+gui_layer)
  rsft         (t! th _               $toggle_rsft+gui_layer)

;; "" GUI_LAYER """"""""""""""""""""""""""""""
)

