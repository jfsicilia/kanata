;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !GUI_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!gui_layer)
  ;; gui button enables windows, desktops, panes and tabs access.
  
  ;; == WORKSPACES ===================
  $s/work      (t! th XX $toggle_!workspaces_layer)
  $!lmet/work  (t! th XX $toggle_!workspaces_layer)

  ;; == PANES ========================
  $d/pane      (t! th $~action_pane_toggle $toggle_!panes_layer)
  $!lalt/pane  (t! th $~action_pane_toggle $toggle_!panes_layer)

  ;; == TABS =========================
  $f/tabs      (t! th $~action_tab_toggle $toggle_!tabs_layer)
  $!lctl/tabs  (t! th $~action_tab_toggle $toggle_!tabs_layer)

  ;; == WINDOWS ======================
  h            $action_wnd_left
  $l/work      (t! th $action_wnd_right $toggle_!workspaces_layer)
  $k/pane      (t! th $action_wnd_up    $toggle_!panes_layer)
  $j/tabs      (t! th $action_wnd_down  $toggle_!tabs_layer)

  ;; == SPC/SFT ======================
  spc          (t! th $action_wnd_max $toggle_!lsft+gui_layer)
  lsft         (t! th _               $toggle_!lsft+gui_layer)
  rsft         (t! th _               $toggle_!rsft+gui_layer)

;; "" !GUI_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LSFT+GUI_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
