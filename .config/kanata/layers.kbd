;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lalt_layer)

  ;; == KEY COMBOS ===================
  spc $action_select_command

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_!lalt+lctl_layer)
  $f|lctl|autofill (t! th _ $toggle_!lalt+lctl_layer)
  $j|lctl|jump (t! th _ $toggle_!lalt+lctl_layer)
                                                                 
  ;; == LMET =========================                           
  $!lmet  (t! th _ $toggle_!lalt+lmet_layer)
  $a|lmet|action (t! th _ $toggle_!lalt+lmet_layer)
  $;|lmet|command (t! th _ $toggle_!lalt+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d|lsft|def (t! th _ $toggle_!lalt+lsft_layer)
  lsft    (t! th _ $toggle_!lalt+lsft_layer)
  $k|rsft|keymap (t! th _ $toggle_!lalt+rsft_layer)
  rsft    (t! th _ $toggle_!lalt+rsft_layer)

;; "" !LALT_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
