  $k/rsft (t! th _ $toggle_!rsft+lctl+lalt+lmet_layer)
  rsft    (t! th _ $toggle_!rsft+lctl+lalt+lmet_layer)

;; "" !LCTL+LALT+LMET_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LSFT+LCTL+LALT+LMET_LAYER """""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lsft+lctl+lalt+lmet_layer)

;; "" !LSFT+LCTL+LALT+LMET_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !RSFT+LCTL+LALT+LMET_LAYER """""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!rsft+lctl+lalt+lmet_layer)

;; "" !RSFT+LCTL+LALT+LMET_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft_layer)
  ;; Pressing lsft+rsft (in that order) issues tab_next action.
  rsft (multi (release-key lsft) $action_tab_next)

  ent $action_sft+ent

  
  ;; == PANES ========================
  $a/gui     (t! th _ (multi (release-key lsft) $toggle_panes_layer))
  $;/gui     (t! th _ (multi (release-key lsft) $toggle_panes_layer))
  $lang/!gui (t! th _ (multi (release-key lsft) $toggle_!panes_layer))

  $apps      (t! th _ $toggle_lsft+apps_layer)
  $tab/opts  (t! th _ $toggle_lsft+opts_layer)
  $bookmarks (t! th _ $toggle_lsft+bookmarks_layer)
  $esc/omni  (t! th _ $toggle_lsft+omni_layer)
  $f/lctl    (t! th _ $toggle_lsft+lctl_layer)
  $j/lctl    (t! th _ $toggle_lsft+lctl_layer)
  $g/lmet    (t! th _ $toggle_lsft+lmet_layer)
  $h/lmet    (t! th _ $toggle_lsft+lmet_layer)
  $s/lalt    (t! th _ $toggle_lsft+lalt_layer)
  $l/lalt    (t! th _ $toggle_lsft+lalt_layer)
  $!lctl     (t! th _ $toggle_!lsft+lctl_layer)
  $!lalt     (t! th _ $toggle_!lsft+lalt_layer)
  $!lmet     (t! th _ $toggle_!lsft+lmet_layer)

;; "" LSFT_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" RSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (rsft_layer)
  ;; Pressing rsft+lsft (in that order) issues tab_prev combo.
  lsft (multi (release-key rsft) $action_tab_prev)

  ;; == PANES ========================
  $a/gui     (t! th _ (multi (release-key rsft) $toggle_panes_layer))
  $;/gui     (t! th _ (multi (release-key rsft) $toggle_panes_layer))
  $lang/!gui (t! th _ (multi (release-key rsft) $toggle_!panes_layer))

  $apps      (t! th _ $toggle_rsft+apps_layer)
  $tab/opts  (t! th _ $toggle_rsft+opts_layer)
  $bookmarks (t! th _ $toggle_rsft+bookmarks_layer)
  $esc/omni  (t! th _ $toggle_rsft+omni_layer)
  $f/lctl    (t! th _ $toggle_rsft+lctl_layer)
  $j/lctl    (t! th _ $toggle_rsft+lctl_layer)
  $g/lmet    (t! th _ $toggle_rsft+lmet_layer)
  $h/lmet    (t! th _ $toggle_rsft+lmet_layer)
  $s/lalt    (t! th _ $toggle_rsft+lalt_layer)
  $l/lalt    (t! th _ $toggle_rsft+lalt_layer)
  $!lctl     (t! th _ $toggle_!rsft+lctl_layer)
  $!lalt     (t! th _ $toggle_!lsft+lalt_layer)
  $!lmet     (t! th _ $toggle_!lsft+lmet_layer)

;; "" RSFT_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" OPTS_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (opts_layer)
  r (multi  lrld)

  ;; == SPC/SFT ======================
  spc  (t! th _ $toggle_lsft+opts_layer)
  lsft (t! th _ $toggle_lsft+opts_layer)
  rsft (t! th _ $toggle_rsft+opts_layer)
  
;; "" OPTS_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT+OPTS_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft+opts_layer)
  r (multi (cmd kanata_sync_apps.py -f) (cmd kanata_sync_all_apps_interfaces.sh)) 

