;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet_layer)

  ;; == KEY COMBOS ===================

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab $action_tab_next

  ;; == LALT =========================
  $!lalt           (t! th _ $toggle_lmet+lalt_layer)
  $s|lalt|symbol   (t! th _ $toggle_lmet+lalt_layer)
  $l|lalt|localiz  (t! th _ $toggle_lmet+lalt_layer)

  ;; == LCTL =========================
  $!lctl           (t! th _ $toggle_lmet+lctl_layer)
  $f|lctl|autofill (t! th _ $toggle_lmet+lctl_layer)
  $j|lctl|jump     (t! th _ $toggle_lmet+lctl_layer)
  
  ;; == SFT ================
  $d|lsft|def      (t! th _ $toggle_lmet+lsft_layer)
  lsft             (t! th _ $toggle_lmet+lsft_layer)
  $k|rsft|keymap   (t! th _ $toggle_lmet+rsft_layer)
  rsft             (t! th _ $toggle_lmet+rsft_layer)

;; "" LMET_LAYER """""""""""""""""""
) 

