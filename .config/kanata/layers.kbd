;; Layer Toggle Variables ====================================================
;; These define how each layer is activated (which modifiers to hold and
;; which layers to stack). Used by aliases in setup.kbd and by layer maps
;; below.
(defvar
  ;; Apps layer
  toggle_apps_layer                  (t! toggle_layer           apps_layer)
  toggle_lsft+apps_layer             (t! toggle_mod_layer lsft  lsft+apps_layer)
  toggle_rsft+apps_layer             (t! toggle_mod_layer rsft  rsft+apps_layer)

  ;; Num layer
  toggle_num_layer                   (t! toggle_layer           num_layer)
  toggle_lsft+num_layer              (t! toggle_mod_layer lsft  lsft+num_layer)
  toggle_rsft+num_layer              (t! toggle_mod_layer rsft  rsft+num_layer)

  ;; Opts layer
  toggle_opts_layer                  (t! toggle_layer           opts_layer)
  toggle_lsft+opts_layer             (t! toggle_mod_layer lsft  lsft+opts_layer)
  toggle_rsft+opts_layer             (t! toggle_mod_layer rsft  rsft+opts_layer)

  ;; Gui layer
  toggle_gui_layer                   (t! toggle_layer           gui_layer)
  toggle_lsft+gui_layer              (t! toggle_mod_layer lsft  lsft+gui_layer)
  toggle_rsft+gui_layer              (t! toggle_mod_layer rsft  rsft+gui_layer)
  toggle_!gui_layer                  (t! toggle_2layer          gui_layer      !gui_layer)
  toggle_!lsft+gui_layer             (t! toggle_mod_2layer lsft lsft+gui_layer !lsft+gui_layer)
  toggle_!rsft+gui_layer             (t! toggle_mod_2layer rsft rsft+gui_layer !rsft+gui_layer)

  ;; Workspaces layer
  toggle_workspaces_layer            (t! toggle_layer           workspaces_layer)
  toggle_lsft+workspaces_layer       (t! toggle_mod_layer lsft  lsft+workspaces_layer)
  toggle_rsft+workspaces_layer       (t! toggle_mod_layer rsft  rsft+workspaces_layer)
  toggle_!workspaces_layer           (t! toggle_2layer          workspaces_layer      !workspaces_layer)
  toggle_!lsft+workspaces_layer      (t! toggle_mod_2layer lsft lsft+workspaces_layer !lsft+workspaces_layer)
  toggle_!rsft+workspaces_layer      (t! toggle_mod_2layer rsft rsft+workspaces_layer !rsft+workspaces_layer)

  ;; Tabs layer
  toggle_tabs_layer                  (t! toggle_layer           tabs_layer)
  toggle_lsft+tabs_layer             (t! toggle_mod_layer lsft  lsft+tabs_layer)
  toggle_rsft+tabs_layer             (t! toggle_mod_layer rsft  rsft+tabs_layer)
  toggle_!tabs_layer                 (t! toggle_2layer          tabs_layer       !tabs_layer)
  toggle_!lsft+tabs_layer            (t! toggle_mod_2layer lsft lsft+tabs_layer  !lsft+tabs_layer)
  toggle_!rsft+tabs_layer            (t! toggle_mod_2layer rsft rsft+tabs_layer  !rsft+tabs_layer)

  ;; Panes layer
  toggle_panes_layer                 (t! toggle_layer           panes_layer)
  toggle_lsft+panes_layer            (t! toggle_mod_layer lsft  lsft+panes_layer)
  toggle_rsft+panes_layer            (t! toggle_mod_layer rsft  rsft+panes_layer)
  toggle_!panes_layer                (t! toggle_2layer          panes_layer      !panes_layer)
  toggle_!lsft+panes_layer           (t! toggle_mod_2layer lsft lsft+panes_layer !lsft+panes_layer)
  toggle_!rsft+panes_layer           (t! toggle_mod_2layer rsft rsft+panes_layer !rsft+panes_layer)
  toggle_ralt+panes_layer            (t! toggle_mod_layer ralt  ralt+panes_layer)
  toggle_!ralt+panes_layer           (t! toggle_mod_2layer ralt ralt+panes_layer !ralt+panes_layer)
  toggle_rctl+panes_layer            (t! toggle_mod_layer rctl  rctl+panes_layer)
  toggle_!rctl+panes_layer           (t! toggle_mod_2layer rctl rctl+panes_layer !rctl+panes_layer)

  ;; Bookmarks layer
  toggle_bookmarks_layer             (t! toggle_layer           bookmarks_layer)
  toggle_lsft+bookmarks_layer        (t! toggle_mod_layer lsft  lsft+bookmarks_layer)
  toggle_rsft+bookmarks_layer        (t! toggle_mod_layer rsft  rsft+bookmarks_layer)

  ;; Omni layer
  toggle_omni_layer                  (t! toggle_layer           omni_layer)
  toggle_lsft+omni_layer             (t! toggle_mod_layer lsft  lsft+omni_layer)
  toggle_rsft+omni_layer             (t! toggle_mod_layer rsft  rsft+omni_layer)

  ;; Shift layers.
  toggle_lsft_layer                  (t! toggle_mod_layer lsft  lsft_layer)
  toggle_rsft_layer                  (t! toggle_mod_layer rsft  rsft_layer)

  ;; LCtl layers.
  toggle_lctl_layer                  (t! toggle_mod_layer   lctl           lctl_layer)
  toggle_lsft+lctl_layer             (t! toggle_2mod_layer  lctl lsft      lsft+lctl_layer)
  toggle_rsft+lctl_layer             (t! toggle_2mod_layer  lctl rsft      rsft+lctl_layer)
  toggle_!lctl_layer                 (t! toggle_mod_2layer  lctl           lctl_layer      !lctl_layer)
  toggle_!lsft+lctl_layer            (t! toggle_2mod_2layer lctl lsft      lsft+lctl_layer !lsft+lctl_layer)
  toggle_!rsft+lctl_layer            (t! toggle_2mod_2layer lctl rsft      rsft+lctl_layer !rsft+lctl_layer)

  ;; LCtl+LAlt layers.
  toggle_lctl+lalt_layer             (t! toggle_2mod_layer  lctl lalt      lctl+lalt_layer)
  toggle_lsft+lctl+lalt_layer        (t! toggle_3mod_layer  lctl lalt lsft lsft+lctl+lalt_layer)
  toggle_rsft+lctl+lalt_layer        (t! toggle_3mod_layer  lctl lalt rsft rsft+lctl+lalt_layer)
  toggle_!lctl+lalt_layer            (t! toggle_2mod_2layer lctl lalt      lctl+lalt_layer      !lctl+lalt_layer)
  toggle_!lsft+lctl+lalt_layer       (t! toggle_3mod_2layer lctl lalt lsft lsft+lctl+lalt_layer !lsft+lctl+lalt_layer)
  toggle_!rsft+lctl+lalt_layer       (t! toggle_3mod_2layer lctl lalt rsft rsft+lctl+lalt_layer !rsft+lctl+lalt_layer)
  ;; LCtl+Lmet layers.
  toggle_lctl+lmet_layer             (t! toggle_2mod_layer  lctl lmet      lctl+lmet_layer)
  toggle_lsft+lctl+lmet_layer        (t! toggle_3mod_layer  lctl lmet lsft lsft+lctl+lmet_layer)
  toggle_rsft+lctl+lmet_layer        (t! toggle_3mod_layer  lctl lmet rsft rsft+lctl+lmet_layer)
  toggle_!lctl+lmet_layer            (t! toggle_2mod_2layer lctl lmet      lctl+lmet_layer      !lctl+lmet_layer)
  toggle_!lsft+lctl+lmet_layer       (t! toggle_3mod_2layer lctl lmet lsft lsft+lctl+lmet_layer !lsft+lctl+lmet_layer)
  toggle_!rsft+lctl+lmet_layer       (t! toggle_3mod_2layer lctl lmet rsft rsft+lctl+lmet_layer !rsft+lctl+lmet_layer)

  ;; LAlt layers.
  toggle_lalt_layer                  (t! toggle_mod_layer   lalt           lalt_layer)
  toggle_lsft+lalt_layer             (t! toggle_2mod_layer  lalt lsft      lsft+lalt_layer)
  toggle_rsft+lalt_layer             (t! toggle_2mod_layer  lalt rsft      rsft+lalt_layer)
  toggle_!lalt_layer                 (t! toggle_mod_2layer  lalt           lalt_layer      !lalt_layer)
  toggle_!lsft+lalt_layer            (t! toggle_2mod_2layer lalt lsft      lsft+lalt_layer !lsft+lalt_layer)
  toggle_!rsft+lalt_layer            (t! toggle_2mod_2layer lalt rsft      rsft+lalt_layer !rsft+lalt_layer)
  ;; LAlt+LCtl layers.
  toggle_lalt+lctl_layer             (t! toggle_2mod_layer  lalt lctl      lctl+lalt_layer)
  toggle_lsft+lalt+lctl_layer        (t! toggle_3mod_layer  lalt lctl lsft lsft+lctl+lalt_layer)
  toggle_rsft+lalt+lctl_layer        (t! toggle_3mod_layer  lalt lctl rsft rsft+lctl+lalt_layer)
  toggle_!lalt+lctl_layer            (t! toggle_2mod_2layer lalt lctl      lctl+lalt_layer      !lctl+lalt_layer)
  toggle_!lsft+lalt+lctl_layer       (t! toggle_3mod_2layer lalt lctl lsft lsft+lctl+lalt_layer !lsft+lctl+lalt_layer)
  toggle_!rsft+lalt+lctl_layer       (t! toggle_3mod_2layer lalt lctl rsft rsft+lctl+lalt_layer !rsft+lctl+lalt_layer)
  ;; LAlt+LMet layers.
  toggle_lalt+lmet_layer             (t! toggle_2mod_layer  lalt lmet      lalt+lmet_layer)
  toggle_lsft+lalt+lmet_layer        (t! toggle_3mod_layer  lalt lmet lsft lsft+lalt+lmet_layer)
  toggle_rsft+lalt+lmet_layer        (t! toggle_3mod_layer  lalt lmet rsft rsft+lalt+lmet_layer)
  toggle_!lalt+lmet_layer            (t! toggle_2mod_2layer lalt lmet      lalt+lmet_layer      !lalt+lmet_layer)
  toggle_!lsft+lalt+lmet_layer       (t! toggle_3mod_2layer lalt lmet lsft lsft+lalt+lmet_layer !lsft+lalt+lmet_layer)
  toggle_!rsft+lalt+lmet_layer       (t! toggle_3mod_2layer lalt lmet rsft rsft+lalt+lmet_layer !rsft+lalt+lmet_layer)

  ;; LMet layers.
  toggle_lmet_layer                  (t! toggle_mod_layer   lmet           lmet_layer)
  toggle_lsft+lmet_layer             (t! toggle_2mod_layer  lmet lsft      lsft+lmet_layer)
  toggle_rsft+lmet_layer             (t! toggle_2mod_layer  lmet rsft      rsft+lmet_layer)
  toggle_!lmet_layer                 (t! toggle_mod_2layer  lmet           lmet_layer      !lmet_layer)
  toggle_!lsft+lmet_layer            (t! toggle_2mod_2layer lmet lsft      lsft+lmet_layer !lsft+lmet_layer)
  toggle_!rsft+lmet_layer            (t! toggle_2mod_2layer lmet rsft      rsft+lmet_layer !rsft+lmet_layer)
  ;; LMet+LCtl layers.
  toggle_lmet+lctl_layer             (t! toggle_2mod_layer  lmet lctl      lctl+lmet_layer)
  toggle_lsft+lmet+lctl_layer        (t! toggle_3mod_layer  lmet lctl lsft lsft+lctl+lmet_layer)
  toggle_rsft+lmet+lctl_layer        (t! toggle_3mod_layer  lmet lctl rsft rsft+lctl+lmet_layer)
  toggle_!lmet+lctl_layer            (t! toggle_2mod_2layer lmet lctl      lctl+lmet_layer      !lctl+lmet_layer)
  toggle_!lsft+lmet+lctl_layer       (t! toggle_3mod_2layer lmet lctl lsft lsft+lctl+lmet_layer !lsft+lctl+lmet_layer)
  toggle_!rsft+lmet+lctl_layer       (t! toggle_3mod_2layer lmet lctl rsft rsft+lctl+lmet_layer !rsft+lctl+lmet_layer)
  ;; LMet+lalt layers.
  toggle_lmet+lalt_layer             (t! toggle_2mod_layer  lmet lalt      lalt+lmet_layer)
  toggle_lsft+lmet+lalt_layer        (t! toggle_3mod_layer  lmet lalt lsft lsft+lalt+lmet_layer)
  toggle_rsft+lmet+lalt_layer        (t! toggle_3mod_layer  lmet lalt rsft rsft+lalt+lmet_layer)
  toggle_!lmet+lalt_layer            (t! toggle_2mod_2layer lmet lalt      lalt+lmet_layer      !lalt+lmet_layer)
  toggle_!lsft+lmet+lalt_layer       (t! toggle_3mod_2layer lmet lalt lsft lsft+lalt+lmet_layer !lsft+lalt+lmet_layer)
  toggle_!rsft+lmet+lalt_layer       (t! toggle_3mod_2layer lmet lalt rsft rsft+lalt+lmet_layer !rsft+lalt+lmet_layer)

  ;; LCtl+LAlt+LMet
  toggle_lctl+lalt+lmet_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lctl+lmet+lalt_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lalt+lctl+lmet_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lalt+lmet+lctl_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lmet+lctl+lalt_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lmet+lalt+lctl_layer        (t! toggle_3mod_layer  lctl lalt lmet      lctl+lalt+lmet_layer)
  toggle_lsft+lctl+lalt+lmet_layer   (t! toggle_4mod_layer  lctl lalt lmet lsft lsft+lctl+lalt+lmet_layer)
  toggle_rsft+lctl+lalt+lmet_layer   (t! toggle_4mod_layer  lctl lalt lmet rsft rsft+lctl+lalt+lmet_layer)
  toggle_!lctl+lalt+lmet_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lctl+lmet+lalt_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lalt+lctl+lmet_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lalt+lmet+lctl_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lmet+lctl+lalt_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lmet+lalt+lctl_layer       (t! toggle_3mod_2layer lctl lalt lmet      lctl+lalt+lmet_layer      !lctl+lalt+lmet_layer)
  toggle_!lsft+lctl+lalt+lmet_layer  (t! toggle_4mod_2layer lctl lalt lmet lsft lsft+lctl+lalt+lmet_layer !lsft+lctl+lalt+lmet_layer)
  toggle_!rsft+lctl+lalt+lmet_layer  (t! toggle_4mod_2layer lctl lalt lmet rsft rsft+lctl+lalt+lmet_layer !rsft+lctl+lalt+lmet_layer)
)

;; Layer Maps ================================================================

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LCTL_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lctl_layer)
  ;; lctl is configured in the physical lalt key (like the cmd key in mac).
  ;; Special treatment is used to allow lctl+tab to mimic alt+tab to switch 
  ;; apps and lctl+` to mimic alt+` to switch apps of the same class.

  ;; == FOCUS APP ===================
  ;; Virtual key vk_lalt is "pressed" on first tab pressed and will be
  ;; "released" when lclt is released.
  tab (switch 
        ((input virtual vk_lalt)) (unmod (lctl) tab) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) tab)) break
  )
  ;; Virtual key vk_lalt is "pressed" on first ` pressed and will be
  ;; "released" when lclt is released.
  grv (switch 
        ((input virtual vk_lalt)) (unmod (lctl) grv) break
        () (multi (on-press press-vkey vk_lalt) lalt (unmod (lctl) grv)) break
  )

  (t! map_keys_with_pattern_except (a d g h k l s ;) "$action_lctl+")
  
  ;; == WORKSPACES ===================
  $a/gui     (t! th $action_lctl+a (multi (release-key lctl) $toggle_tabs_layer))
  $;/gui     (t! th $action_lctl+; (multi (release-key lctl) $toggle_tabs_layer))
  $lang/!gui (t! th _ (multi (release-key lctl) $toggle_!tabs_layer))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lctl+lalt_layer)
  $s/lalt (t! th $action_lctl+s $toggle_lctl+lalt_layer)
  $l/lalt (t! th $action_lctl+l $toggle_lctl+lalt_layer)

  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_lctl+lmet_layer)
  $g/lmet (t! th $action_lctl+g $toggle_lctl+lmet_layer)
  $h/lmet (t! th $action_lctl+g $toggle_lctl+lmet_layer)

  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lctl_layer)
  $d/lsft (t! th $action_lctl+d $toggle_lsft+lctl_layer)
  lsft    (t! th _ $toggle_lsft+lctl_layer)
  $k/rsft (t! th $action_lctl+k $toggle_rsft+lctl_layer)
  rsft    (t! th _ $toggle_rsft+lctl_layer)
  
;; "" LCTL_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT+LCTL_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft+lctl_layer)

  ;; == KEY COMBOS ===================
  (t! default_map_keys_except (s l g h))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lsft+lctl+lalt_layer)
  $s/lalt (t! th _ $toggle_lsft+lctl+lalt_layer)
  $l/lalt (t! th _ $toggle_lsft+lctl+lalt_layer)

  ;; == lmet =========================
  $!lmet  (t! th _ $toggle_lsft+lctl+lmet_layer)
  $g/lmet (t! th _ $toggle_lsft+lctl+lmet_layer)
  $h/lmet (t! th _ $toggle_lsft+lctl+lmet_layer)

;; "" LSFT+LCTL_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" RSFT+LCTL_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (rsft+lctl_layer)

  ;; == KEY COMBOS ===================
  (t! default_map_keys_except (s l g h))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_rsft+lctl+lalt_layer)
  $s/lalt (t! th _ $toggle_rsft+lctl+lalt_layer)
  $l/lalt (t! th _ $toggle_rsft+lctl+lalt_layer)

  ;; == lmet =========================
  $!lmet  (t! th _ $toggle_rsft+lctl+lmet_layer)
  $g/lmet (t! th _ $toggle_rsft+lctl+lmet_layer)
  $h/lmet (t! th _ $toggle_rsft+lctl+lmet_layer)
;; "" RSFT+LCTL_LAYER """""""""""""""
)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LCTL_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lctl_layer)

  ;; == KEY COMBOS ===================
  spc $action_select_files 

  (t! map_keys_with_pattern_except (a d g h k l s ;) "$action_!lctl+")

  ;; == WORKSPACES ===================
  $a/gui     (t! th $action_!lctl+a (multi (release-key $!lctl) $toggle_tabs_layer))
  $;/gui     (t! th $action_!lctl+; (multi (release-key $!lctl) $toggle_tabs_layer))
  $lang/!gui (t! th _ (multi (release-key $!lctl) $toggle_!tabs_layer))

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_!lctl+lalt_layer)
  $s/lalt (t! th $action_!lctl+s $toggle_!lctl+lalt_layer)
  $l/lalt (t! th $action_!lctl+l $toggle_!lctl+lalt_layer)
                                                                 
  ;; == LMET =========================                           
  $!lmet  (t! th _ $toggle_!lctl+lmet_layer)
  $g/lmet (t! th $action_!lctl+g  $toggle_!lctl+lmet_layer)
  $h/lmet (t! th $action_!lctl+h  $toggle_!lctl+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th $action_!lctl+d $toggle_!lsft+lctl_layer)
  lsft    (t! th _ $toggle_!lsft+lctl_layer)
  $k/rsft (t! th $action_!lctl+k $toggle_!rsft+lctl_layer)
  rsft    (t! th _ $toggle_!rsft+lctl_layer)

;; "" !LCTL_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LSFT+LCTL_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lsft+lctl_layer)
  ;; == KEY COMBOS ===================
  spc $action_select_opened_files 

  (t! default_map_keys_except ())

;; "" !LSFT+LCTL_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !RSFT+LCTL_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!rsft+lctl_layer)
  ;; == KEY COMBOS ===================
  spc $action_select_folders

  (t! default_map_keys_except ())

;; "" !RSFT+LCTL_LAYER """""""""""""""
)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lalt_layer)
  ;; == KEY COMBOS ===================

  ;; lalt is configured in the physical lmet key (like the opt key in mac).
  ;; alt+tab works as alt+`
  tab grv

  ;; == WORKSPACES ===================
  $a/gui     (t! th _ (multi (release-key lalt) $toggle_workspaces_layer))
  $;/gui     (t! th _ (multi (release-key lalt) $toggle_workspaces_layer))
  $lang/!gui (t! th _ (multi (release-key lalt) $toggle_!workspaces_layer))

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_lalt+lctl_layer)
  $f/lctl (t! th _ $toggle_lalt+lctl_layer)
  $j/lctl (t! th _ $toggle_lalt+lctl_layer)

  ;; == LMET =========================
  $!lmet  (t! th _ $toggle_lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_lalt+lmet_layer)
 
  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lalt_layer)
  $d/lsft (t! th _ $toggle_lsft+lalt_layer)
  lsft    (t! th _ $toggle_lsft+lalt_layer)
  $k/rsft (t! th _ $toggle_rsft+lalt_layer)
  rsft    (t! th _ $toggle_rsft+lalt_layer)

;; "" LALT_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT+LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft+lalt_layer)

;; "" LSFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" RSFT+LALT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (rsft+lalt_layer)

;; "" RSFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""
)


;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lalt_layer)

  ;; == KEY COMBOS ===================
  spc $action_select_command

  ;; == WORKSPACES ===================
  $a/gui     (t! th _ (multi (release-key $!lalt) $toggle_panes_layer))
  $;/gui     (t! th _ (multi (release-key $!lalt) $toggle_panes_layer))
  $lang/!gui (t! th _ (multi (release-key $!lalt) $toggle_!panes_layer))

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_!lalt+lctl_layer)
  $f/lctl (t! th _ $toggle_!lalt+lctl_layer)
  $j/lctl (t! th _ $toggle_!lalt+lctl_layer)
                                                                 
  ;; == LMET =========================                           
  $!lmet  (t! th _ $toggle_!lalt+lmet_layer)
  $g/lmet (t! th _ $toggle_!lalt+lmet_layer)
  $h/lmet (t! th _ $toggle_!lalt+lmet_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lalt_layer)
  lsft    (t! th _ $toggle_!lsft+lalt_layer)
  $k/rsft (t! th _ $toggle_!rsft+lalt_layer)
  rsft    (t! th _ $toggle_!rsft+lalt_layer)

;; "" !LALT_LAYER """""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LSFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lsft+lalt_layer)

;; "" !LSFT+LALT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !RSFT+LALT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!rsft+lalt_layer)

;; "" !RSFT+LALT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lmet_layer)

  ;; == KEY COMBOS ===================

  ;; lmet+tab mimics original lctl+tab functionality (typically next tab in 
  ;; browsers and editors).
  tab $action_tab_next

  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_lmet+lalt_layer)
  $s/lalt (t! th _ $toggle_lmet+lalt_layer)
  $l/lalt (t! th _ $toggle_lmet+lalt_layer)

  ;; == LCTL =========================
  $!lctl  (t! th _ $toggle_lmet+lctl_layer)
  $f/lctl (t! th _ $toggle_lmet+lctl_layer)
  $j/lctl (t! th _ $toggle_lmet+lctl_layer)
  
  ;; == SPC/LSFT/RSFT ================
  spc     (t! th _ $toggle_lsft+lmet_layer)
  $d/lsft (t! th _ $toggle_lsft+lmet_layer)
  lsft    (t! th _ $toggle_lsft+lmet_layer)
  $k/rsft (t! th _ $toggle_rsft+lmet_layer)
  rsft    (t! th _ $toggle_rsft+lmet_layer)

;; "" LMET_LAYER """""""""""""""""""
) 

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT+LMET_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft+lmet_layer)

  tab $action_tab_prev
;; "" LSFT+LMET_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
