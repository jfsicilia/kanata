  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lctl+lalt+lmet_layer)
  lsft    (t! th _ $toggle_!lsft+lctl+lalt+lmet_layer)
  $k/rsft (t! th _ $toggle_!rsft+lctl+lalt+lmet_layer)
