  i 8
  o 9
  j 4
  k 5 
  l 6
  m 1
  , 2
  . 3
  ralt .

  ;; == SPC/SFT ======================
  lsft (t! th _ $toggle_num+lsft_layer)
  rsft (t! th _ $toggle_num+rsft_layer)
  
