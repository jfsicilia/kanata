(deflayermap (!lctl+lmet_layer)
  ;; == LALT =========================
  $!lalt  (t! th _ $toggle_!lctl+lmet+lalt_layer)
  $s/lalt (t! th _ $toggle_!lctl+lmet+lalt_layer)
  $l/lalt (t! th _ $toggle_!lctl+lmet+lalt_layer)

  ;; == LSFT/RSFT ====================
  $d/lsft (t! th _ $toggle_!lsft+lctl+lmet_layer)
  lsft    (t! th _ $toggle_!lsft+lctl+lmet_layer)
  $k/rsft (t! th _ $toggle_!rsft+lctl+lmet_layer)
  rsft    (t! th _ $toggle_!rsft+lctl+lmet_layer)
  
;; "" !LCTL+LMET_LAYER """""""""""""""""""
)

