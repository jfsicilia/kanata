;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (rsft+opts_layer)
  r $action_restart_kwanata

;; "" RSFT+OPTS_LAYER """"""""""""""""""""""""""
)

