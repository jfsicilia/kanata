  2     $action_pane_go_2
  3     $action_pane_go_3
  4     $action_pane_go_4
  5     $action_pane_go_5
  6     $action_pane_go_6
  7     $action_pane_go_7
  8     $action_pane_go_8
  9     $action_pane_go_last

  ;; toggle/open panes
  b     $action_pane_bookmarks
  c     $action_pane_calendar
  d     $action_pane_day
  e     $action_pane_explorer
  g     $action_pane_go
  m     $action_pane_main
  o     $action_pane_outline
  p     $action_pane_properties
  s     $action_pane_left_sidebar
  t     $action_pane_tags
  v     $action_pane_vertical_tabs
  ;     $action_pane_graph
  ,     $action_pane_backlinks
  .     $action_pane_outlinks

  ;; == SPC/SFT ======================
  spc  (t! th $action_pane_max $toggle_lsft+panes_layer)
  lsft (t! th _               $toggle_lsft+panes_layer)
  rsft (t! th _               $toggle_rsft+panes_layer)
  ralt (t! th _               $toggle_ralt+panes_layer)
  rctl (t! th _               $toggle_rctl+panes_layer)

  ;; "" PANES_LAYER """"""""""""""""""""""""
)

