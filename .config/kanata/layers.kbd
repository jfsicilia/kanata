;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LCTL+LALT+LMET+LSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lctl+lalt+lmet+lsft_layer)

;; "" !LCTL+LALT+LMET+LSFT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" !LCTL+LALT+LMET+RSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (!lctl+lalt+lmet+rsft_layer)

;; "" !LCTL+LALT+LMET+RSFT_LAYER """""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" LSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (lsft_layer)
  ;; Pressing lsft+rsft (in that order) issues tab_next action.
  rsft (multi (release-key lsft) $action_tab_next)

  ent $action_sft+ent

  $ralt|apps        (t! th _ $toggle_apps+lsft_layer)
  $tab|open         (t! th _ $toggle_opts+lsft_layer)
  $prnt|bookm       (t! th _ $toggle_bookmarks+lsft_layer)
  $esc|omni         (t! th _ $toggle_omni+lsft_layer)
  $f|lctl|autofill  (t! th _ $toggle_lctl+lsft_layer)
  $j|lctl|jump      (t! th _ $toggle_lctl+lsft_layer)
  $a|lmet|action    (t! th _ $toggle_lmet+lsft_layer)
  $;|lmet|command   (t! th _ $toggle_lmet+lsft_layer)
  $s|lalt|symbol    (t! th _ $toggle_lalt+lsft_layer)
  $l|lalt|localiz   (t! th _ $toggle_lalt+lsft_layer)
  $!lctl            (t! th _ $toggle_!lctl+lsft_layer)
  $!lalt            (t! th _ $toggle_!lalt+lsft_layer)
  $!lmet            (t! th _ $toggle_!lmet+lsft_layer)

;; "" LSFT_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" RSFT_LAYER """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (rsft_layer)
  ;; Pressing rsft+lsft (in that order) issues tab_prev combo.
  lsft (multi (release-key rsft) $action_tab_prev)

  $ralt|apps        (t! th _ $toggle_apps+rsft_layer)
  $tab|open         (t! th _ $toggle_opts+rsft_layer)
  $prnt|bookm       (t! th _ $toggle_bookmarks+rsft_layer)
  $esc|omni         (t! th _ $toggle_omni+rsft_layer)
  $f|lctl|autofill  (t! th _ $toggle_lctl+rsft_layer)
  $j|lctl|jump      (t! th _ $toggle_lctl+rsft_layer)
  $a|lmet|action    (t! th _ $toggle_lmet+rsft_layer)
  $;|lmet|command   (t! th _ $toggle_lmet+rsft_layer)
  $s|lalt|symbol    (t! th _ $toggle_lalt+rsft_layer)
  $l|lalt|localiz   (t! th _ $toggle_lalt+rsft_layer)
  $!lctl            (t! th _ $toggle_!lctl+rsft_layer)
  $!lalt            (t! th _ $toggle_!lalt+lsft_layer)
  $!lmet            (t! th _ $toggle_!lmet+lsft_layer)

;; "" RSFT_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" OPTS_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (opts_layer)
  r (multi  lrld)

  ;; == SFT ======================
  lsft (t! th _ $toggle_opts+lsft_layer)
  rsft (t! th _ $toggle_opts+rsft_layer)
  
;; "" OPTS_LAYER """"""""""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" OPTS+LSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (opts+lsft_layer)
  r (multi (cmd kanata_sync_apps.py -f) (cmd kanata_sync_all_apps_interfaces.sh)) 

;; "" OPTS+LSFT_LAYER """"""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; "" OPTS+RSFT_LAYER """""""""""""""""""""""""""""""""""""""""""""""""""""""""
;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
(deflayermap (opts+rsft_layer)
  r $action_restart_kwanata

;; "" OPTS+RSFT_LAYER """"""""""""""""""""""""""
)

;; """"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
