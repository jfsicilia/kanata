    ((input virtual vk_obsidian)) A-e break
    () XX break
  ))
  action_pane_!explorer (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-S-e break
    () XX break
  ))
  action_pane_find (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-S-f break
    () XX break
  ))
  action_pane_go (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-o break
    () XX break
  ))
  action_pane_main (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-m break
    () XX break
  ))
  action_pane_outline (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-o break
    () XX break
