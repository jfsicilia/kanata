    () XX break
  ))
  action_pane_outlinks (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-. break
    () XX break
  ))
  action_pane_!outlinks (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-S-. break
    () XX break
  ))

  ;; == Window combos ======================================================
  action_wnd_up    (t! unmod_all  M-up)
  action_wnd_down  (t! unmod_all M-down)
  action_wnd_left  (t! unmod_all M-left)
  action_wnd_right (t! unmod_all M-right)
  action_wnd_max   (t! unmod_all M-m)

  action_move_wnd_next_screen  (t! unmod_all M-S-right)
  action_move_wnd_prev_screen  (t! unmod_all M-S-left)
  action_move_wnd_next_desktop (t! unmod_all M-C-S-right)
  action_move_wnd_prev_desktop (t! unmod_all M-C-S-left)

  action_close_app (t! unmod_all A-f4)

  ;; == Desktop combos =====================================================
  ;;action_next_desktop M-C-right
  ;;action_prev_desktop M-C-left
  action_next_desktop (t! unmod_all M-C-right)
  action_prev_desktop (t! unmod_all M-C-left)
  action_next_screen  (t! unmod_all M-S-down)
  action_prev_screen  (t! unmod_all M-S-up)

  ;; == History combos =====================================================
  ;; Ctrl+] ;;""
  action_hist_next (t! unmod_all (switch
    ((input virtual vk_chrome))   A-right                 break
    ((input virtual vk_obsidian)) C-A-right               break
    ((input virtual vk_nvim))     C-i                     break 
    () XX break
  ))
  ;; Ctrl+[
  action_hist_prev (t! unmod_all (switch
    ((input virtual vk_chrome))   A-left                  break
    ((input virtual vk_obsidian)) C-A-left                break
    ((input virtual vk_nvim))     C-o                     break 
    () XX break
  ))

  ;; == Edit combos ======================================================
  ;; Ctrl+b can't be bound in foot, so kanata intercepts it send the 
  ;; corresponding correct foot's keybinding for page up.
  action_page_up (t! unmod_all (switch
    ((input virtual vk_foot)) S-pgup break
    ((input virtual vk_obsidian)) C-b break
    () C-b break
  ))

  ;; Ctrl+f can't be bound in foot, so kanata intercepts it send the 
  ;; corresponding correct foot's keybinding for page down.
  action_page_down (t! unmod_all (switch
    ((input virtual vk_foot)) S-pgdn break
    ((input virtual vk_obsidian)) C-f break
    () C-f break
  ))

  action_up (switch
    ((input virtual vk_nvim)) C-k break
    () up break
  )
  action_down (switch
    ((input virtual vk_nvim)) C-j break
    () down break
  )
  action_left (switch
    ((input virtual vk_nvim)) C-h break
    () left break
  )
  action_right (switch
    ((input virtual vk_nvim)) C-l break
    () right break
  )
  ;;action_shift_up (t! unmod_all (switch
  ;;  ((input virtual vk_nvim)) C-k break
  ;;  () S-up break
  ;;))
  ;;action_shift_down (t! unmod_all (switch
  ;;  ((input virtual vk_nvim)) C-j break
  ;;  () S-down break
  ;;))
  ;;action_shift_left (t! unmod_all (switch
