  ;;  () S-left break
  ;;))
  ;;action_shift_right (t! unmod_all (switch
  ;;  ((input virtual vk_nvim)) C-l break
  ;;  () S-right break
  ;;))

  action_copy (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-c break
    () C-c break
  ))
  action_cut (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-x break
    () C-x break
  ))
  action_paste (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-v break
    () C-p break
  ))
  action_undo (t! unmod_all (switch
    () C-z break
  ))
  action_redo (t! unmod_all (switch
    () C-S-z break
  ))
  action_rename (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-r break
    () XX break
  ))
  action_duplicate (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-d break
    () XX break
  ))
  action_toggle_select (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-spc break
    () XX break
  ))
  action_select_all (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-a break
    () XX break
  ))
  action_invert_select (t! unmod_all (switch
    ((input virtual vk_obsidian)) A-S-a break
    () XX break
  ))
  action_clear_select (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-S-a break
    () XX break
  ))
  action_new (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-n break
    () XX break
  ))
  action_!new (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-S-n break
    () XX break
  ))
  action_!!new (t! unmod_all (switch
    ((input virtual vk_obsidian)) C-A-s break
    () XX break
  ))


  action_open (t! unmod_all (switch
    ((input virtual vk_obsidian)) right break
    ((input virtual vk_dolphin)) ent break
    () right break
  ))

  action_parent (t! unmod_all (switch
    ((input virtual vk_obsidian)) left break
    ((input virtual vk_dolphin)) bspc break
    () left break
  ))

  ;; == Misc combos =__=====================================================
  action_restart_kwanata (t! unmod_all 
    (macro RA-spc 300 s y s t e m c t l spc - - u s e r spc r e s t a r t spc k w a n a t a 300 ent))

)
